        $txtUserSearch.Add_KeyDown(\{\par
            if ($_.KeyCode -eq 'Enter') \{\par
                Search-BulkUsers $txtUserSearch.Text.Trim() $lbUsers $lblUserCount\par
            \}\par
        \})\par
        \par
        $btnSelectAll.Add_Click(\{\par
            for ($i = 0; $i -lt $lbUsers.Items.Count; $i++) \{\par
                $lbUsers.SetItemChecked($i, $true)\par
            \}\par
            Update-UserSelectionCount $lbUsers $lblUserCount\par
        \})\par
        \par
        $lbUsers.Add_ItemCheck(\{\par
            # D\'e9lai pour permettre la mise \'e0 jour de l'\'e9tat\par
            $timer = New-Object System.Windows.Forms.Timer\par
            $timer.Interval = 10\par
            $timer.Add_Tick(\{\par
                Update-UserSelectionCount $lbUsers $lblUserCount\par
                $timer.Stop()\par
                $timer.Dispose()\par
            \})\par
            $timer.Start()\par
        \})\par
        \par
        $btnSearchGroups.Add_Click(\{\par
            Search-BulkGroups $txtGroupSearch.Text.Trim() $lbGroups\par
        \})\par
        \par
        $txtGroupSearch.Add_KeyDown(\{\par
            if ($_.KeyCode -eq 'Enter') \{\par
                Search-BulkGroups $txtGroupSearch.Text.Trim() $lbGroups\par
            \}\par
        \})\par
        \par
        $lbGroups.Add_SelectedIndexChanged(\{\par
            if ($lbGroups.SelectedItem) \{\par
                $selectedGroup = $lbGroups.SelectedItem.ToString()\par
                if ($selectedGroup -match '^([^-]+)') \{\par
                    $groupName = $matches[1].Trim()\par
                    $lblGroupSelected.Text = "Groupe s\'e9lectionn\'e9 : $groupName"\par
                    $btnAddToGroup.Enabled = ($lbUsers.CheckedItems.Count -gt 0)\par
                    $btnRemoveFromGroup.Enabled = ($lbUsers.CheckedItems.Count -gt 0)\par
                \}\par
            \} else \{\par
                $lblGroupSelected.Text = "Groupe s\'e9lectionn\'e9 : Aucun"\par
                $btnAddToGroup.Enabled = $false\par
                $btnRemoveFromGroup.Enabled = $false\par
            \}\par
        \})\par
        \par
        $btnAddToGroup.Add_Click(\{\par
            Execute-BulkGroupOperation $lbUsers $lbGroups $txtResults "add"\par
        \})\par
        \par
        $btnRemoveFromGroup.Add_Click(\{\par
            Execute-BulkGroupOperation $lbUsers $lbGroups $txtResults "remove"\par
        \})\par
        \par
        $btnClearResults.Add_Click(\{\par
            $txtResults.Text = "R\'e9sultats effac\'e9s"\par
        \})\par
        \par
        $btnClose.Add_Click(\{\par
            $bulkForm.Close()\par
        \})\par
        \par
        # Ajout des contr\'f4les au formulaire\par
        $bulkForm.Controls.AddRange(@($headerPanel, $userPanel, $groupPanel, $resultPanel))\par
        \par
        # Affichage du formulaire\par
        $null = $bulkForm.ShowDialog()\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de l'affichage de la gestion en lot: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur" "Impossible d'afficher la fen\'eatre de gestion en lot: $($_.Exception.Message)"\par
    \}\par
\}\par
