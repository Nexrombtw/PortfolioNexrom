        \par
        $lblCity = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "Ville :"\par
            Location = [System.Drawing.Point]::new(20, 35)\par
            Size = [System.Drawing.Size]::new(50, 25)\par
            TextAlign = 'MiddleRight'\par
            ForeColor = $script:Theme.Text\par
            Font = [System.Drawing.Font]::new("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)\par
        \}\par
        \par
        $script:UIControls.cbCity = New-Object System.Windows.Forms.ComboBox -Property @\{\par
            Location = [System.Drawing.Point]::new(80, 33)\par
            Width = 130\par
            DropDownStyle = 'DropDownList'\par
            BackColor = $script:Theme.White\par
            ForeColor = $script:Theme.Text\par
            Font = [System.Drawing.Font]::new("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)\par
            DrawMode = 'OwnerDrawFixed'\par
        \}\par
        \par
        # \'c9v\'e9nement pour dessiner l'\'e9toile en jaune\par
        $script:UIControls.cbCity.Add_DrawItem(\{\par
            param($sender, $e)\par
            \par
            if ($e.Index -ge 0) \{\par
                $item = $sender.Items[$e.Index].ToString()\par
                $e.DrawBackground()\par
                \par
                if ($item.StartsWith("\f1\u11088?\f0 ")) \{\par
                    $starBrush = [System.Drawing.SolidBrush]::new([System.Drawing.Color]::Gold)\par
                    $textBrush = [System.Drawing.SolidBrush]::new($e.ForeColor)\par
                    \par
                    $e.Graphics.DrawString("\f1\u11088?\f0 ", $e.Font, $starBrush, $e.Bounds.Left + 2, $e.Bounds.Top + 2)\par
                    $cityName = $item.Substring(2)\par
                    $e.Graphics.DrawString($cityName, $e.Font, $textBrush, $e.Bounds.Left + 20, $e.Bounds.Top + 2)\par
                    \par
                    $starBrush.Dispose()\par
                    $textBrush.Dispose()\par
                \} else \{\par
                    $textBrush = [System.Drawing.SolidBrush]::new($e.ForeColor)\par
                    $e.Graphics.DrawString($item, $e.Font, $textBrush, $e.Bounds.Left + 2, $e.Bounds.Top + 2)\par
                    $textBrush.Dispose()\par
                \}\par
                \par
