        Write-Log "Version PowerShell: $($PSVersionTable.PSVersion)" -Level Info\par
        Write-Log "Utilisateur: $env:USERNAME" -Level Info\par
        Write-Log "Ordinateur: $env:COMPUTERNAME" -Level Info\par
        \par
