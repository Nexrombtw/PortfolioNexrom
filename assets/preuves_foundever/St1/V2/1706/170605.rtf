# Dialogue pour saisir le num\'e9ro de s\'e9rie\par
# MODIFI\'c9 : Dialogue pour saisir le num\'e9ro de s\'e9rie avec extraction am\'e9lior\'e9e\par
# MODIFI\'c9 : Dialogue simplifi\'e9 pour saisir le num\'e9ro de s\'e9rie\par
# NOUVELLE FONCTION : Modification de num\'e9ro de s\'e9rie depuis la recherche\par
function Show-SerialNumberDialog \{\par
    param([string]$ComputerName = $null)\par
    \par
    try \{\par
        # Si pas de nom fourni, utiliser la s\'e9lection de la liste principale\par
        if ([string]::IsNullOrWhiteSpace($ComputerName)) \{\par
            if (-not $script:UIControls.lbComputers.SelectedItem) \{\par
                Show-InfoMessage "Veuillez s\'e9lectionner un ordinateur."\par
                return\par
            \}\par
            \par
            $selectedText = $script:UIControls.lbComputers.SelectedItem.ToString()\par
            if ($selectedText -match "Aucun ordinateur|Veuillez s\'e9lectionner|Ville introuvable|Erreur de chargement|Tous les PC ont") \{\par
                return\par
            \}\par
            \par
            $ComputerName = $selectedText\par
            $ComputerName = ($ComputerName -split ' \\[')[0]\par
            $ComputerName = ($ComputerName -split ' - ')[0]\par
            $ComputerName = $ComputerName.Trim()\par
        \}\par
        \par
        # Formulaire simplifi\'e9\par
        $dialogForm = New-Object System.Windows.Forms.Form -Property @\{\par
            Text = "Num\'e9ro de s\'e9rie - $ComputerName"\par
            Size = [System.Drawing.Size]::new(450, 200)\par
            StartPosition = "CenterParent"\par
            FormBorderStyle = 'FixedDialog'\par
            MaximizeBox = $false\par
            MinimizeBox = $false\par
            BackColor = $script:Theme.Background\par
        \}\par
        \par
        $lblInstruction = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "Veuillez entrer le num\'e9ro de s\'e9rie :"\par
            Location = [System.Drawing.Point]::new(20, 20)\par
            Size = [System.Drawing.Size]::new(400, 20)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)\par
            ForeColor = $script:Theme.Primary\par
        \}\par
        \par
        $lblComputer = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "Ordinateur : $ComputerName"\par
            Location = [System.Drawing.Point]::new(20, 45)\par
            Size = [System.Drawing.Size]::new(400, 20)\par
            ForeColor = $script:Theme.Text\par
        \}\par
        \par
        $txtSerial = New-Object System.Windows.Forms.TextBox -Property @\{\par
            Location = [System.Drawing.Point]::new(20, 75)\par
            Size = [System.Drawing.Size]::new(400, 25)\par
            BackColor = $script:Theme.White\par
            MaxLength = 50\par
        \}\par
        \par
        $btnOK = New-Object System.Windows.Forms.Button -Property @\{\par
            Text = "Valider"\par
            Location = [System.Drawing.Point]::new(260, 120)\par
            Size = [System.Drawing.Size]::new(80, 30)\par
            BackColor = $script:Theme.ButtonPrimary\par
            ForeColor = $script:Theme.White\par
            FlatStyle = 'Flat'\par
        \}\par
        \par
        $btnCancel = New-Object System.Windows.Forms.Button -Property @\{\par
            Text = "Annuler"\par
            Location = [System.Drawing.Point]::new(350, 120)\par
            Size = [System.Drawing.Size]::new(80, 30)\par
            BackColor = $script:Theme.ButtonSecondary\par
            ForeColor = $script:Theme.White\par
            FlatStyle = 'Flat'\par
        \}\par
        \par
        $btnOK.Add_Click(\{\par
            $serialNumber = $txtSerial.Text.Trim()\par
            \par
            if ([string]::IsNullOrWhiteSpace($serialNumber)) \{\par
                Show-InfoMessage "Veuillez saisir un num\'e9ro de s\'e9rie."\par
                return\par
            \}\par
            \par
            if ($serialNumber.Length -lt 3) \{\par
                Show-InfoMessage "Le num\'e9ro de s\'e9rie doit contenir au moins 3 caract\'e8res."\par
                return\par
            \}\par
            \par
            try \{\par
                Update-ComputerSerialInAD $ComputerName $serialNumber\par
                $dialogForm.Close()\par
            \} catch \{\par
                Show-ErrorMessage "Erreur de mise \'e0 jour" $_.Exception.Message\par
            \}\par
        \})\par
        \par
        $txtSerial.Add_KeyDown(\{\par
            if ($_.KeyCode -eq 'Enter') \{\par
                $btnOK.PerformClick()\par
            \}\par
        \})\par
        \par
        $btnCancel.Add_Click(\{ $dialogForm.Close() \})\par
        \par
        $dialogForm.Add_Shown(\{ $txtSerial.Focus() \})\par
        \par
        $dialogForm.Controls.AddRange(@($lblInstruction, $lblComputer, $txtSerial, $btnOK, $btnCancel))\par
        $dialogForm.ShowDialog()\par
        \par
    \} catch \{\par
        Show-ErrorMessage "Erreur" $_.Exception.Message\par
    \}\par
\}\par
