# Chargement des villes avec \'e9toile pour les favoris\par
function Load-Cities \{\par
    try \{\par
        $script:UIControls.cbCity.Items.Clear()\par
        $favoriteCity = Load-FavoriteCity\par
        \par
        $root = New-Object System.DirectoryServices.DirectoryEntry("LDAP://$($script:Config.BaseOU)")\par
        $searcher = New-Object System.DirectoryServices.DirectorySearcher($root)\par
        $searcher.Filter = "(objectCategory=organizationalUnit)"\par
        $searcher.SearchScope = [System.DirectoryServices.SearchScope]::OneLevel\par
        $searcher.PropertiesToLoad.Add("ou") | Out-Null\par
        $searcher.ServerTimeLimit = [TimeSpan]::FromSeconds($script:Config.TimeoutSeconds)\par
        \par
        $ous = $searcher.FindAll() | ForEach-Object \{\par
            if ($_.Properties["ou"].Count -gt 0) \{ \par
                $_.Properties["ou"][0] \par
            \}\par
        \} | Sort-Object\par
        \par
        if ($ous.Count -gt 0) \{\par
            foreach ($ou in $ous) \{ \par
                if ($ou -eq $favoriteCity) \{\par
                    $script:UIControls.cbCity.Items.Add("\f1\u11088?\f0  $ou")\par
                \} else \{\par
                    $script:UIControls.cbCity.Items.Add($ou)\par
                \}\par
            \}\par
            Write-Log "Charg\'e9 $($ous.Count) villes depuis AD" -Level Info\par
        \} else \{\par
            Write-Log "Aucune OU trouv\'e9e dans AD" -Level Warning\par
            return $false\par
        \}\par
        \par
        if ($favoriteCity) \{\par
            $favoriteWithStar = "\f1\u11088?\f0  $favoriteCity"\par
            if ($script:UIControls.cbCity.Items.Contains($favoriteWithStar)) \{\par
                $script:UIControls.cbCity.SelectedItem = $favoriteWithStar\par
            \} elseif ($script:UIControls.cbCity.Items.Contains($favoriteCity)) \{\par
                $script:UIControls.cbCity.SelectedItem = $favoriteCity\par
            \}\par
        \} elseif ($script:UIControls.cbCity.Items.Count -gt 0) \{\par
            $script:UIControls.cbCity.SelectedIndex = 0\par
        \}\par
        \par
        return $true\par
    \} catch \{\par
        Write-Log "Erreur critique lors du chargement des villes: $($_.Exception.Message)" -Level Error\par
        return $false\par
    \}\par
\}\par
