# Fonction de validation AD avec retry\par
function Test-ADConnection \{\par
    param([int]$MaxRetries = $script:Config.MaxRetries)\par
    \par
    for ($i = 1; $i -le $MaxRetries; $i++) \{\par
        try \{\par
            $domain = Get-ADDomain -ErrorAction Stop\par
            Write-Log "Connexion AD r\'e9ussie au domaine: $($domain.DNSRoot)" -Level Info\par
            return $true\par
        \} catch \{\par
            Write-Log "Tentative $i/$MaxRetries - Erreur de connexion AD: $($_.Exception.Message)" -Level Warning\par
            if ($i -lt $MaxRetries) \{\par
                Start-Sleep -Seconds 2\par
            \}\par
        \}\par
    \}\par
    return $false\par
\}\par
