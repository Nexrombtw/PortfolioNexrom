# NOUVELLE FONCTION : Extraction de la ville depuis le Distinguished Name\par
function Get-UserCityFromDN \{\par
    param([string]$DistinguishedName)\par
    \par
    try \{\par
        # Pattern pour extraire la ville : OU=VilleName,OU=FR,DC=...\par
        if ($DistinguishedName -match "OU=([^,]+),OU=FR,DC=") \{\par
            $extractedCity = $matches[1]\par
            \par
            # V\'e9rifier que cette ville existe dans notre liste\par
            $root = New-Object System.DirectoryServices.DirectoryEntry("LDAP://$($script:Config.BaseOU)")\par
            $searcher = New-Object System.DirectoryServices.DirectorySearcher($root)\par
            $searcher.Filter = "(&(objectCategory=organizationalUnit)(ou=$extractedCity))"\par
            $searcher.SearchScope = [System.DirectoryServices.SearchScope]::OneLevel\par
            $result = $searcher.FindOne()\par
            \par
            if ($result) \{\par
                Write-Log "Ville d\'e9tect\'e9e depuis DN : $extractedCity" -Level Debug\par
                return $extractedCity\par
            \} else \{\par
                Write-Log "Ville '$extractedCity' non trouv\'e9e dans la liste des villes disponibles" -Level Warning\par
            \}\par
        \} else \{\par
            Write-Log "Impossible d'extraire la ville depuis le DN : $DistinguishedName" -Level Warning\par
        \}\par
        \par
        return $null\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de l'extraction de la ville : $($_.Exception.Message)" -Level Warning\par
        return $null\par
    \}\par
\}\par
\par
# NOUVELLE FONCTION : Synchronisation de la ville dans le ComboBox principal\par
function Sync-MainCitySelection \{\par
    param([string]$CityName)\par
    \par
    try \{\par
        if ([string]::IsNullOrWhiteSpace($CityName)) \{\par
            return\par
        \}\par
        \par
        # Chercher la ville avec ou sans \'e9toile dans le ComboBox principal\par
        $cityWithStar = "\f1\u11088?\f0  $CityName"\par
        $cityFound = $false\par
        \par
        # V\'e9rifier d'abord avec l'\'e9toile (ville favorite)\par
        if ($script:UIControls.cbCity.Items.Contains($cityWithStar)) \{\par
            $script:UIControls.cbCity.SelectedItem = $cityWithStar\par
            $cityFound = $true\par
            Write-Log "Ville favorite s\'e9lectionn\'e9e automatiquement : $CityName" -Level Info\par
        \}\par
        # Sinon chercher sans \'e9toile\par
        elseif ($script:UIControls.cbCity.Items.Contains($CityName)) \{\par
            $script:UIControls.cbCity.SelectedItem = $CityName\par
            $cityFound = $true\par
            Write-Log "Ville s\'e9lectionn\'e9e automatiquement : $CityName" -Level Info\par
        \}\par
        \par
        if ($cityFound) \{\par
            # IMPORTANT : D\'e9clencher manuellement l'\'e9v\'e9nement de changement de ville\par
            # pour mettre \'e0 jour les ordinateurs et vider la liste des utilisateurs\par
            try \{\par
                $script:UIControls.lbUsers.Items.Clear()\par
                Clear-UserDetails\par
                Load-ComputersWithoutSerial\par
                Write-Log "Interface mise \'e0 jour automatiquement pour la ville : $CityName" -Level Info\par
            \} catch \{\par
                Write-Log "Erreur lors de la mise \'e0 jour de l'interface : $($_.Exception.Message)" -Level Warning\par
            \}\par
        \} else \{\par
            Write-Log "Ville '$CityName' non trouv\'e9e dans le ComboBox principal" -Level Warning\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la synchronisation de la ville : $($_.Exception.Message)" -Level Warning\par
    \}\par
\}\par
\par
# MODIFI\'c9 : D\'e9placement d'utilisateur avec synchronisation automatique de la ville\par
function Move-UserToOU \{\par
    try \{\par
        if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un utilisateur."\par
            return\par
        \}\par
        \par
        $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
        if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
            $samAccountName = $matches[1]\par
        \} else \{\par
            Show-ErrorMessage "Erreur" "Impossible d'identifier l'utilisateur s\'e9lectionn\'e9."\par
            return\par
        \}\par
        \par
        # R\'e9cup\'e9ration des informations utilisateur\par
        $user = Get-ADUser -Identity $samAccountName -Properties DistinguishedName, GivenName, Surname -ErrorAction Stop\par
        \par
        # NOUVEAU : D\'e9tection automatique de la ville de l'utilisateur\par
        $detectedCity = Get-UserCityFromDN $user.DistinguishedName\par
        \par
        # NOUVEAU : Synchronisation automatique de la ville dans le ComboBox principal\par
        if ($detectedCity) \{\par
            Sync-MainCitySelection $detectedCity\par
            Write-Log "Ville principale synchronis\'e9e automatiquement : $detectedCity" -Level Info\par
        \}\par
        \par
        # Interface de d\'e9placement avec ville pr\'e9-s\'e9lectionn\'e9e\par
        Show-UniformMoveInterface $user $detectedCity\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors du d\'e9placement: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur" "Impossible d'ouvrir la fen\'eatre de d\'e9placement: $($_.Exception.Message)"\par
    \}\par
\}\par
\par
# Affichage des d\'e9tails utilisateur\par
function Show-UserDetails \{\par
    try \{\par
        Clear-UserDetails\par
        \par
        if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
            return\par
        \}\par
        \par
        $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
        if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
            $samAccountName = $matches[1]\par
        \} else \{\par
            Write-Log "Impossible d'extraire le nom d'utilisateur de: $selectedText" -Level Warning\par
            return\par
        \}\par
        \par
        Write-Log "Affichage des d\'e9tails pour: $samAccountName" -Level Debug\par
        \par
        $user = Get-ADUser -Identity $samAccountName -Properties * -ErrorAction Stop\par
        \par
        # Changement du texte du bouton selon l'\'e9tat du compte\par
        if ($script:UIControls.btnDisable) \{\par
            if ($user.Enabled) \{\par
                $script:UIControls.btnDisable.Text = "D\'e9sactiver compte"\par
                $script:UIControls.btnDisable.BackColor = $script:Theme.ButtonSecondary\par
            \} else \{\par
                $script:UIControls.btnDisable.Text = "Activer compte"\par
                $script:UIControls.btnDisable.BackColor = [System.Drawing.Color]::FromArgb(34, 139, 34)\par
            \}\par
        \}\par
        \par
        # Remplissage des champs\par
        if ($script:UIControls.detail["Path"]) \{ \par
            $script:UIControls.detail["Path"].Text = $user.DistinguishedName\par
        \}\par
        if ($script:UIControls.detail["Nom"]) \{ \par
            $script:UIControls.detail["Nom"].Text = Get-ValueOrDefault $user.Surname ""\par
        \}\par
        if ($script:UIControls.detail["Prenom"]) \{ \par
            $script:UIControls.detail["Prenom"].Text = Get-ValueOrDefault $user.GivenName ""\par
        \}\par
        if ($script:UIControls.detail["Service"]) \{ \par
            $script:UIControls.detail["Service"].Text = Get-ValueOrDefault $user.Department ""\par
        \}\par
        if ($script:UIControls.detail["Matricule"]) \{ \par
            $script:UIControls.detail["Matricule"].Text = Get-ValueOrDefault $user.EmployeeID ""\par
        \}\par
        if ($script:UIControls.detail["Mail"]) \{ \par
            $script:UIControls.detail["Mail"].Text = Get-ValueOrDefault $user.EmailAddress ""\par
        \}\par
        if ($script:UIControls.detail["Session"]) \{ \par
            $script:UIControls.detail["Session"].Text = $user.SamAccountName \par
        \}\par
        \par
        # \'c9tat du compte\par
        $accountStatus = if ($user.Enabled) \{\par
            "Compte actif"\par
        \} else \{\par
            "Compte d\'e9sactiv\'e9"\par
        \}\par
        if ($script:UIControls.detail["Etat"]) \{ \par
            $script:UIControls.detail["Etat"].Text = $accountStatus \par
        \}\par
        \par
        # Dates avec formatage\par
        if ($script:UIControls.detail["Exp"]) \{\par
            $script:UIControls.detail["Exp"].Text = if ($user.AccountExpirationDate) \{\par
                $user.AccountExpirationDate.ToString("dd/MM/yyyy HH:mm")\par
            \} else \{\par
                "Jamais"\par
            \}\par
        \}\par
        \par
        if ($script:UIControls.detail["ExpPwd"]) \{\par
            if ($user.PasswordLastSet) \{\par
                try \{\par
                    $pwdPolicy = Get-ADDefaultDomainPasswordPolicy\par
                    $pwdExpiry = $user.PasswordLastSet.AddDays($pwdPolicy.MaxPasswordAge.Days)\par
                    $script:UIControls.detail["ExpPwd"].Text = $pwdExpiry.ToString("dd/MM/yyyy HH:mm")\par
                \} catch \{\par
                    $script:UIControls.detail["ExpPwd"].Text = "Inconnu"\par
                \}\par
            \} else \{\par
                $script:UIControls.detail["ExpPwd"].Text = "Jamais d\'e9fini"\par
            \}\par
        \}\par
        \par
        if ($script:UIControls.detail["LastLogon"]) \{\par
            $script:UIControls.detail["LastLogon"].Text = if ($user.LastLogonDate) \{\par
                $user.LastLogonDate.ToString("dd/MM/yyyy HH:mm")\par
            \} else \{\par
                "Jamais connect\'e9"\par
            \}\par
        \}\par
        \par
        if ($script:UIControls.detail["Created"]) \{\par
            $script:UIControls.detail["Created"].Text = if ($user.Created) \{\par
                $user.Created.ToString("dd/MM/yyyy HH:mm")\par
            \} else \{\par
                "Inconnu"\par
            \}\par
        \}\par
        \par
        # Chargement des groupes\par
        try \{\par
            $groups = Get-ADPrincipalGroupMembership -Identity $samAccountName -ErrorAction Stop | \par
                     Select-Object -ExpandProperty Name | \par
                     Sort-Object\par
            \par
            if ($script:UIControls.lbGrps) \{\par
                foreach ($group in $groups) \{\par
                    $script:UIControls.lbGrps.Items.Add($group)\par
                \}\par
            \}\par
            \par
            Write-Log "Charg\'e9 $($groups.Count) groupes pour $samAccountName" -Level Debug\par
        \} catch \{\par
            Write-Log "Erreur lors du chargement des groupes pour $samAccountName : $($_.Exception.Message)" -Level Warning\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de l'affichage des d\'e9tails : $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur d'affichage" "Impossible d'afficher les d\'e9tails de l'utilisateur: $($_.Exception.Message)"\par
    \}\par
\}\par
\par
# Fonction pour d\'e9sactiver un compte utilisateur\par
function Disable-UserAccount \{\par
    try \{\par
        if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un utilisateur."\par
            return\par
        \}\par
        \par
        $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
        if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
            $samAccountName = $matches[1]\par
        \} else \{\par
            Show-ErrorMessage "Erreur de s\'e9lection" "Impossible d'identifier l'utilisateur s\'e9lectionn\'e9."\par
            return\par
        \}\par
        \par
        $user = Get-ADUser -Identity $samAccountName -Properties Surname, GivenName, Enabled, DistinguishedName, Description -ErrorAction Stop\par
        \par
        if (-not $user.Enabled) \{\par
            Show-InfoMessage "Le compte de $($user.GivenName) $($user.Surname) est d\'e9j\'e0 d\'e9sactiv\'e9."\par
            return\par
        \}\par
        \par
        # D\'e9terminer la ville d'origine\par
        $currentDN = $user.DistinguishedName\par
        $userCity = "Wasquehal"\par
        \par
        if ($currentDN -match "OU=([^,]+),OU=FR,DC=") \{\par
            $extractedCity = $matches[1]\par
            try \{\par
                $root = New-Object System.DirectoryServices.DirectoryEntry("LDAP://$($script:Config.BaseOU)")\par
                $searcher = New-Object System.DirectoryServices.DirectorySearcher($root)\par
                $searcher.Filter = "(&(objectCategory=organizationalUnit)(ou=$extractedCity))"\par
                $searcher.SearchScope = [System.DirectoryServices.SearchScope]::OneLevel\par
                $result = $searcher.FindOne()\par
                \par
                if ($result) \{\par
                    $userCity = $extractedCity\par
                    Write-Log "Ville d'origine d\'e9tect\'e9e : $userCity pour $samAccountName" -Level Info\par
                \}\par
            \} catch \{\par
                Write-Log "Erreur lors de la d\'e9tection de la ville, utilisation de Wasquehal par d\'e9faut" -Level Warning\par
            \}\par
        \}\par
        \par
        $confirmMessage = "ATTENTION - D\'c9SACTIVATION DE COMPTE`n`n" +\par
                         "Vous \'eates sur le point de d\'e9sactiver le compte de :`n`n" +\par
                         "Utilisateur : $($user.GivenName) $($user.Surname)`n" +\par
                         "Identifiant : $samAccountName`n" +\par
                         "Ville d'origine d\'e9tect\'e9e : $userCity`n`n" +\par
                         "Cette action va :`n" +\par
                         "\f2\bullet  D\f0\'e9sactiver le compte`n" +\par
                         "\f2\bullet  D\f0\'e9placer vers l'OU 'Disable Users' de $userCity`n" +\par
                         "\f2\bullet  Retirer de tous les groupes (sauf Domain Users)`n`n" +\par
                         "Voulez-vous continuer ?"\par
        \par
        if (-not (Show-ConfirmDialog $confirmMessage "Confirmation de d\f0\'e9sactivation")) \{\par
            return\par
        \}\par
        \par
        # Construire le chemin de l'OU\par
        $disabledOUPath = "OU=Disable Users,OU=Others,OU=$userCity,OU=FR,DC=Marche,DC=lan"\par
        $ouExists = $false\par
        \par
        try \{\par
            $null = Get-ADOrganizationalUnit -Identity $disabledOUPath -ErrorAction Stop\par
            $ouExists = $true\par
            Write-Log "OU Disable Users trouv\'e9e pour $userCity : $disabledOUPath" -Level Info\par
        \} catch \{\par
            Write-Log "OU 'Disable Users' introuvable pour $userCity : $disabledOUPath" -Level Warning\par
        \}\par
        \par
        # D\'e9sactiver le compte\par
        try \{\par
            Disable-ADAccount -Identity $samAccountName -ErrorAction Stop\par
            Write-Log "Compte $samAccountName d\'e9sactiv\'e9 avec succ\'e8s" -Level Info\par
            \par
            # MISE \'c0 JOUR AUTOMATIQUE DE L'AFFICHAGE DANS LA LISTE\par
            $currentIndex = $script:UIControls.lbUsers.SelectedIndex\par
            if ($currentIndex -ge 0) \{\par
                $displayText = $script:UIControls.lbUsers.Items[$currentIndex].ToString()\par
                if ($displayText -notmatch '\\[D\'c9SACTIV\'c9\\]') \{\par
                    # Ajouter le marqueur [D\'c9SACTIV\'c9] apr\'e8s le nom d'utilisateur\par
                    $newDisplayText = $displayText -replace '(\\[[^\\]]+\\])', '$1 [D\'c9SACTIV\'c9]'\par
                    $script:UIControls.lbUsers.Items[$currentIndex] = $newDisplayText\par
                \}\par
            \}\par
            \par
            # MISE \'c0 JOUR AUTOMATIQUE DU BOUTON\par
            if ($script:UIControls.btnDisable) \{\par
                $script:UIControls.btnDisable.Text = "Activer compte"\par
                $script:UIControls.btnDisable.BackColor = [System.Drawing.Color]::FromArgb(34, 139, 34)  # Vert pour activation\par
            \}\par
            \par
            # MISE \'c0 JOUR AUTOMATIQUE DE L'\'c9TAT DANS LES D\'c9TAILS\par
            if ($script:UIControls.detail["Etat"]) \{\par
                $script:UIControls.detail["Etat"].Text = "Compte d\'e9sactiv\'e9"\par
                $script:UIControls.detail["Etat"].ForeColor = [System.Drawing.Color]::Red\par
            \}\par
            \par
        \} catch \{\par
            Write-Log "Erreur lors de la d\'e9sactivation du compte: $($_.Exception.Message)" -Level Error\par
            Show-ErrorMessage "Erreur de d\'e9sactivation" "Impossible de d\'e9sactiver le compte: $($_.Exception.Message)"\par
            return\par
        \}\par
        \par
        # D\'e9placer vers l'OU appropri\'e9e (version s\'e9curis\'e9e)\par
        if ($ouExists) \{\par
            try \{\par
                $originalDescription = $user.Description\par
                Move-ADObject -Identity $user.DistinguishedName -TargetPath $disabledOUPath -ErrorAction Stop\par
                Write-Log "Compte $samAccountName d\'e9plac\'e9 vers OU Disable Users de $userCity" -Level Info\par
                \par
                # Restaurer la description avec retry\par
                if (-not [string]::IsNullOrEmpty($originalDescription)) \{\par
                    $retryCount = 0\par
                    do \{\par
                        try \{\par
                            Start-Sleep -Milliseconds 500\par
                            Set-ADUser -Identity $samAccountName -Description $originalDescription -ErrorAction Stop\par
                            Write-Log "Description restaur\'e9e pour $samAccountName" -Level Debug\par
                            break\par
                        \} catch \{\par
                            $retryCount++\par
                            if ($retryCount -ge 3) \{\par
                                Write-Log "Impossible de restaurer la description apr\'e8s 3 tentatives" -Level Warning\par
                                break\par
                            \}\par
                            Start-Sleep -Seconds 1\par
                        \}\par
                    \} while ($retryCount -lt 3)\par
                \}\par
                \par
                # MISE \'c0 JOUR DU CHEMIN AD DANS LES D\'c9TAILS\par
                if ($script:UIControls.detail["Path"]) \{\par
                    $script:UIControls.detail["Path"].Text = "OU=Disable Users,OU=Others,OU=$userCity,OU=FR,DC=Marche,DC=lan"\par
                \}\par
                \par
                $moveResult = "\f2\bullet  D\f0\'e9plac\'e9 vers l'OU Disable Users de $userCity"\par
            \} catch \{\par
                Write-Log "Erreur lors du d\'e9placement: $($_.Exception.Message)" -Level Warning\par
                $moveResult = "\f2\bullet  Erreur lors du d\f0\'e9placement: $($_.Exception.Message)"\par
            \}\par
        \} else \{\par
            $moveResult = "\f2\bullet  Aucune OU 'Disable Users' disponible - compte non d\f0\'e9plac\'e9"\par
        \}\par
        \par
        # Retirer des groupes (version s\'e9curis\'e9e)\par
        $groupsRemoved = 0\par
        $groupErrors = @()\par
        try \{\par
            $userGroups = Get-ADPrincipalGroupMembership -Identity $samAccountName -ErrorAction Stop\par
            foreach ($group in $userGroups) \{\par
                if ($group.Name -ne "Domain Users") \{\par
                    try \{\par
                        Remove-ADGroupMember -Identity $group.Name -Members $samAccountName -Confirm:$false -ErrorAction Stop\par
                        $groupsRemoved++\par
                        Write-Log "Utilisateur $samAccountName retir\'e9 du groupe $($group.Name)" -Level Debug\par
                    \} catch \{\par
                        $errorMsg = "Erreur suppression groupe $($group.Name): $($_.Exception.Message)"\par
                        $groupErrors += $errorMsg\par
                        Write-Log $errorMsg -Level Warning\par
                    \}\par
                \}\par
            \}\par
            \par
            # MISE \'c0 JOUR DE LA LISTE DES GROUPES\par
            if ($script:UIControls.lbGrps) \{\par
                $script:UIControls.lbGrps.Items.Clear()\par
                $script:UIControls.lbGrps.Items.Add("Domain Users")  # Seul groupe restant\par
            \}\par
            \par
        \} catch \{\par
            Write-Log "Erreur lors de la r\'e9cup\'e9ration des groupes: $($_.Exception.Message)" -Level Warning\par
            $groupErrors += "Impossible de r\'e9cup\'e9rer la liste des groupes"\par
        \}\par
        \par
        $groupResult = if ($groupErrors.Count -gt 0) \{\par
            "\f2\bullet  Retir\f0\'e9 de $groupsRemoved groupe(s) avec $($groupErrors.Count) erreur(s)"\par
        \} else \{\par
            "\f2\bullet  Retir\f0\'e9 de $groupsRemoved groupe(s)"\par
        \}\par
        \par
        $successMessage = "D\'c9SACTIVATION TERMIN\'c9E`n`n" +\par
                         "Le compte de $($user.GivenName) $($user.Surname) a \'e9t\'e9 trait\'e9.`n`n" +\par
                         "Actions effectu\'e9es :`n" +\par
                         "\f2\bullet  Compte d\f0\'e9sactiv\'e9`n" +\par
                         "$moveResult`n" +\par
                         "$groupResult`n`n" +\par
                         "D\'e9sactivation effectu\'e9e le : $(Get-Date -Format "dd/MM/yyyy \'e0 HH:mm:ss")`n" +\par
                         "Par : $env:USERNAME"\par
        \par
        Show-InfoMessage $successMessage "D\'e9sactivation termin\'e9e"\par
        \par
        Write-Log "Processus de d\'e9sactivation termin\'e9 pour $samAccountName" -Level Info\par
        \par
    \} catch \{\par
        Write-Log "Erreur critique lors de la d\'e9sactivation: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur critique" "Erreur lors de la d\'e9sactivation du compte: $($_.Exception.Message)"\par
    \}\par
\}\par
\par
# Fonction pour activer un compte utilisateur\par
function Enable-UserAccount \{\par
    try \{\par
        if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un utilisateur."\par
            return\par
        \}\par
        \par
        $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
        if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
            $samAccountName = $matches[1]\par
        \} else \{\par
            Show-ErrorMessage "Erreur de s\'e9lection" "Impossible d'identifier l'utilisateur s\'e9lectionn\'e9."\par
            return\par
        \}\par
        \par
        $user = Get-ADUser -Identity $samAccountName -Properties Surname, GivenName, Enabled, DistinguishedName, Description -ErrorAction Stop\par
        \par
        if ($user.Enabled) \{\par
            Show-InfoMessage "Le compte de $($user.GivenName) $($user.Surname) est d\'e9j\'e0 activ\'e9."\par
            return\par
        \}\par
        \par
        $confirmMessage = "ACTIVATION DE COMPTE`n`n" +\par
                         "Vous \'eates sur le point d'activer le compte :`n`n" +\par
                         "Utilisateur : $($user.GivenName) $($user.Surname)`n" +\par
                         "Identifiant : $samAccountName`n`n" +\par
                         "Souhaitez-vous continuer ?"\par
        \par
        if (-not (Show-ConfirmDialog $confirmMessage "Confirmation d'activation")) \{\par
            return\par
        \}\par
        \par
        # Activer le compte\par
        try \{\par
            Enable-ADAccount -Identity $samAccountName -ErrorAction Stop\par
            Write-Log "Compte $samAccountName activ\'e9 avec succ\'e8s" -Level Info\par
            \par
            # MISE \'c0 JOUR AUTOMATIQUE DE L'AFFICHAGE DANS LA LISTE\par
            $currentIndex = $script:UIControls.lbUsers.SelectedIndex\par
            if ($currentIndex -ge 0) \{\par
                $displayText = $script:UIControls.lbUsers.Items[$currentIndex].ToString()\par
                if ($displayText -match '\\[D\'c9SACTIV\'c9\\]') \{\par
                    # Enlever le marqueur [D\'c9SACTIV\'c9] de l'affichage\par
                    $newDisplayText = $displayText -replace ' \\[D\'c9SACTIV\'c9\\]', ''\par
                    $script:UIControls.lbUsers.Items[$currentIndex] = $newDisplayText\par
                \}\par
            \}\par
            \par
            # MISE \'c0 JOUR AUTOMATIQUE DU BOUTON\par
            if ($script:UIControls.btnDisable) \{\par
                $script:UIControls.btnDisable.Text = "D\'e9sactiver compte"\par
                $script:UIControls.btnDisable.BackColor = $script:Theme.ButtonSecondary\par
            \}\par
            \par
            # MISE \'c0 JOUR AUTOMATIQUE DE L'\'c9TAT DANS LES D\'c9TAILS\par
            if ($script:UIControls.detail["Etat"]) \{\par
                $script:UIControls.detail["Etat"].Text = "Compte actif"\par
                $script:UIControls.detail["Etat"].ForeColor = [System.Drawing.Color]::Green\par
            \}\par
            \par
        \} catch \{\par
            Write-Log "Erreur lors de l'activation du compte: $($_.Exception.Message)" -Level Error\par
            Show-ErrorMessage "Erreur d'activation" "Impossible d'activer le compte: $($_.Exception.Message)"\par
            return\par
        \}\par
        \par
        # Pr\'e9server la description\par
        $originalDescription = $user.Description\par
        if (-not [string]::IsNullOrEmpty($originalDescription)) \{\par
            Set-ADUser -Identity $samAccountName -Description $originalDescription -ErrorAction SilentlyContinue\par
        \}\par
        \par
        # R\'e9initialiser le mot de passe avec choix\par
        $user2 = Get-ADUser -Identity $samAccountName -Properties EmployeeID -ErrorAction Stop\par
        if (-not [string]::IsNullOrWhiteSpace($user2.EmployeeID)) \{\par
            $newPassword = New-SecurePassword $user2.EmployeeID\par
            $securePassword = ConvertTo-SecureString $newPassword -AsPlainText -Force\par
            Set-ADAccountPassword -Identity $samAccountName -Reset -NewPassword $securePassword\par
            Set-ADUser -Identity $samAccountName -ChangePasswordAtLogon $true\par
            \par
            # NOUVEAU : Copie automatique dans le presse-papier\par
            try \{\par
                [System.Windows.Forms.Clipboard]::SetText($newPassword)\par
                $clipboardStatus = "\f1\u10003?\f0  Mot de passe copi\'e9 dans le presse-papier"\par
                Write-Log "Mot de passe copi\'e9 dans le presse-papier pour $samAccountName" -Level Info\par
            \} catch \{\par
                $clipboardStatus = "\f1\u9888?\f0  Impossible de copier dans le presse-papier"\par
                Write-Log "Erreur lors de la copie dans le presse-papier: $($_.Exception.Message)" -Level Warning\par
            \}\par
            \par
            $passwordMessage = "Bonjour,`nLe mot de passe de $($user.Surname) $($user.GivenName) est r\'e9initialis\'e9 : $newPassword`nIl sera \'e0 modifier \'e0 l'ouverture de session.`n`n$clipboardStatus"\par
            Show-InfoMessage $passwordMessage "Mot de passe"\par
        \}\par
        \par
        # NOUVEAU : Correspondance avec la ville s\'e9lectionn\'e9e dans la fen\'eatre principale\par
        $selectedCityRaw = $script:UIControls.cbCity.SelectedItem.ToString()\par
        $selectedCity = $selectedCityRaw -replace "\f1\u11088?\f0  ", ""\par
        \par
        # Interface de d\'e9placement pr\'e9-configur\'e9e avec la ville correspondante\par
        $updatedUser = Get-ADUser -Identity $samAccountName -Properties DistinguishedName,GivenName,Surname -ErrorAction Stop\par
        Show-UniformMoveInterface $updatedUser $selectedCity\par
        \par
        Write-Log "Processus d'activation termin\'e9 pour $samAccountName" -Level Info\par
        Show-UserDetails\par
        \par
    \} catch \{\par
        Write-Log "Erreur critique lors de l'activation: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur critique" "Erreur lors de l'activation du compte: $($_.Exception.Message)"\par
    \}\par
\}\par
\par
# MODIFI\'c9 : Interface de d\'e9placement avec ville pr\'e9-s\'e9lectionn\'e9e\par
function Show-UniformMoveInterface \{\par
    param(\par
        [Microsoft.ActiveDirectory.Management.ADUser]$User,\par
        [string]$PreSelectedCity = $null\par
    )\par
    \par
    try \{\par
        # Cr\'e9ation de la fen\'eatre principale avec couleurs uniformes\par
        $moveForm = New-Object System.Windows.Forms.Form -Property @\{\par
            Text = "D\'e9placement d'utilisateur"\par
            Size = [System.Drawing.Size]::new(900, 700)\par
            StartPosition = "CenterParent"\par
            FormBorderStyle = 'FixedDialog'\par
            MaximizeBox = $false\par
            MinimizeBox = $false\par
            BackColor = $script:Theme.Background\par
            Font = [System.Drawing.Font]::new("Segoe UI", 9)\par
        \}\par
        \par
        # En-t\'eate avec style uniforme\par
        $headerPanel = New-Object System.Windows.Forms.Panel -Property @\{\par
            Location = [System.Drawing.Point]::new(15, 15)\par
            Size = [System.Drawing.Size]::new(860, 70)\par
            BackColor = $script:Theme.Light\par
            BorderStyle = 'FixedSingle'\par
        \}\par
        \par
        $lblTitle = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "D\'c9PLACEMENT D'UTILISATEUR"\par
            Location = [System.Drawing.Point]::new(15, 15)\par
            Size = [System.Drawing.Size]::new(830, 25)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 12, [System.Drawing.FontStyle]::Bold)\par
            ForeColor = $script:Theme.Primary\par
            TextAlign = 'MiddleCenter'\par
        \}\par
        \par
        $lblUserInfo = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "Utilisateur : $($User.GivenName) $($User.Surname) [$($User.SamAccountName)]"\par
            Location = [System.Drawing.Point]::new(15, 40)\par
            Size = [System.Drawing.Size]::new(830, 20)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 10)\par
            ForeColor = $script:Theme.Text\par
