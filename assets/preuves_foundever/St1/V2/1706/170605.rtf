# MODIFI\'c9 : R\'e9initialisation avec presse-papier et choix "changement \'e0 l'ouverture de session"\par
function Reset-UserPassword \{\par
    try \{\par
        if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un utilisateur."\par
            return\par
        \}\par
        \par
        $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
        if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
            $samAccountName = $matches[1]\par
        \} else \{\par
            Show-ErrorMessage "Erreur de s\'e9lection" "Impossible d'identifier l'utilisateur s\'e9lectionn\'e9."\par
            return\par
        \}\par
        \par
        $user = Get-ADUser -Identity $samAccountName -Properties EmployeeID, Enabled, Surname, GivenName -ErrorAction Stop\par
        \par
        if ([string]::IsNullOrWhiteSpace($user.EmployeeID)) \{\par
            Show-ErrorMessage "Matricule manquant" "Le matricule est requis pour r\'e9initialiser le mot de passe de $samAccountName."\par
            return\par
        \}\par
        \par
        # Dialogue pour choisir le changement \'e0 l'ouverture de session\par
        $changeAtLogonForm = New-Object System.Windows.Forms.Form -Property @\{\par
            Text = "Options de r\'e9initialisation"\par
            Size = [System.Drawing.Size]::new(450, 250)\par
            StartPosition = "CenterParent"\par
            FormBorderStyle = 'FixedDialog'\par
            MaximizeBox = $false\par
            MinimizeBox = $false\par
            BackColor = $script:Theme.Background\par
        \}\par
        \par
        $lblQuestion = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "Forcer le changement de mot de passe \'e0 l'ouverture de session ?"\par
            Location = [System.Drawing.Point]::new(20, 20)\par
            Size = [System.Drawing.Size]::new(400, 40)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)\par
            ForeColor = $script:Theme.Primary\par
            TextAlign = 'MiddleCenter'\par
        \}\par
        \par
        $lblUser = New-Object System.Windows.Forms.Label -Property @\{\par
            Text = "Utilisateur : $($user.GivenName) $($user.Surname) [$samAccountName]"\par
            Location = [System.Drawing.Point]::new(20, 70)\par
            Size = [System.Drawing.Size]::new(400, 20)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 9)\par
            ForeColor = $script:Theme.Text\par
            TextAlign = 'MiddleCenter'\par
        \}\par
        \par
        $chkChangeAtLogon = New-Object System.Windows.Forms.CheckBox -Property @\{\par
            Text = "L'utilisateur doit changer le mot de passe \'e0 l'ouverture de session"\par
            Location = [System.Drawing.Point]::new(20, 110)\par
            Size = [System.Drawing.Size]::new(400, 30)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 9)\par
            ForeColor = $script:Theme.Text\par
            Checked = $true\par
        \}\par
        \par
        $btnOK = New-Object System.Windows.Forms.Button -Property @\{\par
            Text = "R\'e9initialiser"\par
            Location = [System.Drawing.Point]::new(250, 160)\par
            Size = [System.Drawing.Size]::new(100, 30)\par
            BackColor = $script:Theme.ButtonPrimary\par
            ForeColor = $script:Theme.White\par
            FlatStyle = 'Flat'\par
            DialogResult = [System.Windows.Forms.DialogResult]::OK\par
        \}\par
        \par
        $btnCancel = New-Object System.Windows.Forms.Button -Property @\{\par
            Text = "Annuler"\par
            Location = [System.Drawing.Point]::new(360, 160)\par
            Size = [System.Drawing.Size]::new(70, 30)\par
            BackColor = $script:Theme.ButtonSecondary\par
            ForeColor = $script:Theme.White\par
            FlatStyle = 'Flat'\par
            DialogResult = [System.Windows.Forms.DialogResult]::Cancel\par
        \}\par
        \par
        $changeAtLogonForm.Controls.AddRange(@($lblQuestion, $lblUser, $chkChangeAtLogon, $btnOK, $btnCancel))\par
        \par
        $result = $changeAtLogonForm.ShowDialog()\par
        \par
        if ($result -ne [System.Windows.Forms.DialogResult]::OK) \{\par
            return\par
        \}\par
        \par
        $forceChangeAtLogon = $chkChangeAtLogon.Checked\par
        \par
        if (-not $user.Enabled) \{\par
            Set-ADUser -Identity $samAccountName -Enabled $true\par
            Write-Log "Compte $samAccountName activ\'e9" -Level Info\par
        \}\par
        \par
        $newPassword = New-SecurePassword $user.EmployeeID\par
        $securePassword = ConvertTo-SecureString $newPassword -AsPlainText -Force\par
        \par
        Set-ADAccountPassword -Identity $samAccountName -Reset -NewPassword $securePassword\par
        \par
        # Appliquer ou non le changement \'e0 l'ouverture de session\par
        if ($forceChangeAtLogon) \{\par
            Set-ADUser -Identity $samAccountName -ChangePasswordAtLogon $true\par
            Write-Log "Changement de mot de passe \'e0 l'ouverture de session activ\'e9 pour $samAccountName" -Level Info\par
        \} else \{\par
            Set-ADUser -Identity $samAccountName -ChangePasswordAtLogon $false\par
            Write-Log "Changement de mot de passe \'e0 l'ouverture de session d\'e9sactiv\'e9 pour $samAccountName" -Level Info\par
        \}\par
        \par
        # NOUVEAU : Copie automatique dans le presse-papier\par
        try \{\par
            [System.Windows.Forms.Clipboard]::SetText($newPassword)\par
            $clipboardStatus = "\f1\u10003?\f0  Mot de passe copi\'e9 dans le presse-papier"\par
            Write-Log "Mot de passe copi\'e9 dans le presse-papier pour $samAccountName" -Level Info\par
        \} catch \{\par
            $clipboardStatus = "\f1\u9888?\f0  Impossible de copier dans le presse-papier"\par
            Write-Log "Erreur lors de la copie dans le presse-papier: $($_.Exception.Message)" -Level Warning\par
        \}\par
        \par
        # Message personnalis\'e9 avec statut du presse-papier\par
        $changeMessage = if ($forceChangeAtLogon) \{\par
            "Il sera \'e0 modifier \'e0 l'ouverture de session."\par
        \} else \{\par
            "Le mot de passe est d\'e9finitif."\par
        \}\par
        \par
        $successMessage = "Bonjour,`n" +\par
                         "Le mot de passe de $($user.Surname) $($user.GivenName) est r\'e9initialis\'e9 : $newPassword`n" +\par
                         "$changeMessage`n`n" +\par
                         "$clipboardStatus"\par
        \par
        Show-InfoMessage $successMessage "R\'e9initialisation r\'e9ussie"\par
        \par
        Write-Log "Mot de passe r\'e9initialis\'e9 pour $samAccountName (changement \'e0 l'ouverture: $forceChangeAtLogon)" -Level Info\par
        Show-UserDetails\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la r\'e9initialisation du mot de passe: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de r\'e9initialisation" "Impossible de r\'e9initialiser le mot de passe: $($_.Exception.Message)"\par
    \}\par
\}\par
