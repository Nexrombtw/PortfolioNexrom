# NOUVELLE FONCTION : Ex\'e9cution des op\'e9rations en lot\par
function Execute-BulkGroupOperation \{\par
    param(\par
        [System.Windows.Forms.CheckedListBox]$UserList,\par
        [System.Windows.Forms.ListBox]$GroupList,\par
        [System.Windows.Forms.TextBox]$ResultsBox,\par
        [string]$Operation\par
    )\par
    \par
    try \{\par
        if ($UserList.CheckedItems.Count -eq 0) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner au moins un utilisateur."\par
            return\par
        \}\par
        \par
        if (-not $GroupList.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un groupe."\par
            return\par
        \}\par
        \par
        # Extraction du nom du groupe\par
        $selectedGroup = $GroupList.SelectedItem.ToString()\par
        if ($selectedGroup -match '^([^-]+)') \{\par
            $groupName = $matches[1].Trim()\par
        \} else \{\par
            $groupName = $selectedGroup\par
        \}\par
        \par
        # Extraction des utilisateurs s\'e9lectionn\'e9s\par
        $selectedUsers = @()\par
        foreach ($checkedItem in $UserList.CheckedItems) \{\par
            if ($checkedItem.ToString() -match '\\[([^\\]]+)\\]') \{\par
                $selectedUsers += $matches[1]\par
            \}\par
        \}\par
        \par
        $operationText = if ($Operation -eq "add") \{ "AJOUT" \} else \{ "SUPPRESSION" \}\par
        $actionText = if ($Operation -eq "add") \{ "ajouter" \} else \{ "retirer" \}\par
        \par
        $confirmMessage = "$operationText EN LOT`n`n" +\par
                         "Vous \'eates sur le point de $actionText $($selectedUsers.Count) utilisateur(s) " +\par
                         "$(if ($Operation -eq 'add') \{ 'au' \} else \{ 'du' \}) groupe '$groupName'.`n`n" +\par
                         "Utilisateurs concern\'e9s :`n" +\par
                         ($selectedUsers -join "`n") +\par
                         "`n`nContinuer ?"\par
        \par
        if (-not (Show-ConfirmDialog $confirmMessage "Confirmation $operationText")) \{\par
            return\par
        \}\par
        \par
        # Ex\'e9cution des op\'e9rations\par
        $results = @()\par
        $successCount = 0\par
        $errorCount = 0\par
        \par
        $results += "=== $operationText EN LOT - $(Get-Date -Format 'dd/MM/yyyy HH:mm:ss') ==="\par
        $results += "Groupe : $groupName"\par
        $results += "Utilisateurs : $($selectedUsers.Count)"\par
        $results += ""\par
        \par
        foreach ($samAccountName in $selectedUsers) \{\par
            try \{\par
                if ($Operation -eq "add") \{\par
                    # V\'e9rifier si d\'e9j\'e0 membre\par
                    $currentGroups = Get-ADPrincipalGroupMembership -Identity $samAccountName | Select-Object -ExpandProperty Name\par
                    if ($currentGroups -contains $groupName) \{\par
                        $results += "D\'c9J\'c0 MEMBRE - $samAccountName : D\'e9j\'e0 dans le groupe"\par
                    \} else \{\par
                        Add-ADGroupMember -Identity $groupName -Members $samAccountName -ErrorAction Stop\par
                        $results += "SUCC\'c8S - $samAccountName : Ajout\'e9 au groupe"\par
                        $successCount++\par
                    \}\par
                \} else \{\par
                    # V\'e9rifier si membre\par
                    $currentGroups = Get-ADPrincipalGroupMembership -Identity $samAccountName | Select-Object -ExpandProperty Name\par
                    if ($currentGroups -notcontains $groupName) \{\par
                        $results += "PAS MEMBRE - $samAccountName : N'\'e9tait pas dans le groupe"\par
                    \} else \{\par
                        Remove-ADGroupMember -Identity $groupName -Members $samAccountName -Confirm:$false -ErrorAction Stop\par
                        $results += "SUCC\'c8S - $samAccountName : Retir\'e9 du groupe"\par
                        $successCount++\par
                    \}\par
                \}\par
            \} catch \{\par
                $results += "ERREUR - $samAccountName : $($_.Exception.Message)"\par
                $errorCount++\par
            \}\par
        \}\par
        \par
        $results += ""\par
        $results += "=== R\'c9SUM\'c9 ==="\par
        $results += "Succ\'e8s : $successCount"\par
        $results += "Erreurs : $errorCount"\par
        $results += "Total trait\'e9 : $($selectedUsers.Count)"\par
        $results += "================================="\par
        $results += ""\par
        \par
        # Affichage des r\'e9sultats\par
        $ResultsBox.Text = ($results -join "`r`n")\par
        \par
        # Message de fin\par
        $summaryMessage = "$operationText TERMIN\'c9`n`n" +\par
                         "Groupe : $groupName`n" +\par
                         "Utilisateurs trait\'e9s : $($selectedUsers.Count)`n" +\par
                         "Succ\'e8s : $successCount`n" +\par
                         "Erreurs : $errorCount"\par
        \par
        Show-InfoMessage $summaryMessage "Op\'e9ration termin\'e9e"\par
        \par
        Write-Log "$operationText en lot termin\'e9 - Groupe: $groupName, Succ\'e8s: $successCount, Erreurs: $errorCount" -Level Info\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de l'op\'e9ration en lot: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur d'op\'e9ration" "Impossible d'effectuer l'op\'e9ration en lot: $($_.Exception.Message)"\par
    \}\par
\}\par
