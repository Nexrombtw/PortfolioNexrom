# NOUVELLE FONCTION : Mise \'e0 jour du compteur d'utilisateurs s\'e9lectionn\'e9s\par
function Update-UserSelectionCount \{\par
    param(\par
        [System.Windows.Forms.CheckedListBox]$UserList,\par
        [System.Windows.Forms.Label]$CountLabel\par
    )\par
    \par
    $checkedCount = $UserList.CheckedItems.Count\par
    $CountLabel.Text = "$checkedCount utilisateur(s) s\'e9lectionn\'e9(s)"\par
    \par
    if ($checkedCount -gt 0) \{\par
        $CountLabel.ForeColor = [System.Drawing.Color]::Gray\par
    \} else \{\par
        $CountLabel.ForeColor = $script:Theme.Text\par
    \}\par
\}\par
