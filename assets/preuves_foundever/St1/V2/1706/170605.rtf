# FONCTION CORRIG\'c9E : Clear-UserDetails\par
function Clear-UserDetails \{\par
    try \{\par
        # Effacer tous les champs de d\'e9tails\par
        foreach ($key in $script:UIControls.detail.Keys) \{\par
            if ($script:UIControls.detail[$key]) \{\par
                if ($script:UIControls.detail[$key] -is [System.Windows.Forms.TextBox]) \{\par
                    $script:UIControls.detail[$key].Text = ""\par
                \} elseif ($script:UIControls.detail[$key] -is [System.Windows.Forms.Label]) \{\par
                    $script:UIControls.detail[$key].Text = ""\par
                    $script:UIControls.detail[$key].ForeColor = $script:Theme.Text\par
                \}\par
            \}\par
        \}\par
        \par
        # Effacer la liste des groupes\par
        if ($script:UIControls.lbGrps) \{\par
            $script:UIControls.lbGrps.Items.Clear()\par
        \}\par
        \par
        # R\'e9initialiser les boutons\par
        if ($script:UIControls.btnDisable) \{\par
            $script:UIControls.btnDisable.Text = "D\'e9sactiver compte"\par
            $script:UIControls.btnDisable.BackColor = $script:Theme.ButtonSecondary\par
        \}\par
        \par
        if ($script:UIControls.btnReset) \{\par
            $script:UIControls.btnReset.Enabled = $true\par
        \}\par
        \par
        if ($script:UIControls.btnMoveUser) \{\par
            $script:UIControls.btnMoveUser.Enabled = $true\par
        \}\par
        \par
        Write-Log "D\'e9tails utilisateur effac\'e9s" -Level Debug\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de l'effacement des d\'e9tails: $($_.Exception.Message)" -Level Warning\par
    \}\par
\}\par
