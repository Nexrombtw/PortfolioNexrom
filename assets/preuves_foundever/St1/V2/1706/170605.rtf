# NOUVELLE FONCTION : Export des r\'e9sultats de recherche\par
function Export-ComputerSearchResults \{\par
    param(\par
        [System.Windows.Forms.ListView]$ListView,\par
        [string]$CityName\par
    )\par
    \par
    try \{\par
        if ($ListView.Items.Count -eq 0) \{\par
            Show-InfoMessage "Aucun r\'e9sultat \'e0 exporter."\par
            return\par
        \}\par
        \par
        $saveDialog = New-Object System.Windows.Forms.SaveFileDialog -Property @\{\par
            Filter = "Fichiers CSV (*.csv)|*.csv"\par
            FileName = "Ordinateurs_$CityName_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"\par
            Title = "Exporter les r\'e9sultats"\par
        \}\par
        \par
        if ($saveDialog.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) \{\par
            $csvData = @()\par
            \par
            foreach ($item in $ListView.Items) \{\par
                $csvData += [PSCustomObject]@\{\par
                    'Nom' = $item.Text\par
                    'Numero_Serie' = $item.SubItems[1].Text -replace " | ", ""\par
                    'Derniere_Connexion' = $item.SubItems[2].Text -replace "   | ", ""  \par
                    'Etat' = $item.SubItems[3].Text -replace " | ", ""                  \par
                    'Description' = $item.SubItems[4].Text                           \par
                    'Chemin_AD' = $item.SubItems[5].Text                                \par
                    'Ville' = $CityName\par
                    'Date_Export' = Get-Date -Format "dd/MM/yyyy HH:mm:ss"\par
                \}\par
            \}\par
            \par
            $csvData | Export-Csv -Path $saveDialog.FileName -NoTypeInformation -Encoding UTF8 -Delimiter ";"\par
            \par
            Show-InfoMessage "Export r\'e9ussi !`n`nFichier : $($saveDialog.FileName)`nNombre d'ordinateurs : $($csvData.Count)" "Export termin\'e9"\par
            Write-Log "Export CSV r\'e9ussi : $($saveDialog.FileName) ($($csvData.Count) ordinateurs)" -Level Info\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de l'export CSV: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur d'export" "Impossible d'exporter les r\'e9sultats: $($_.Exception.Message)"\par
    \}\par
\}\par
