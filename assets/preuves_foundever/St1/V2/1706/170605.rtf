# MODIFI\'c9 : Chargement des ordinateurs filtr\'e9s par ville s\'e9lectionn\'e9e\par
\par
function Load-ComputersWithoutSerial \{\par
    try \{\par
        $script:UIControls.lbComputers.Items.Clear()\par
        \par
        $selectedCity = ""\par
        if ($script:UIControls.cbCity.SelectedItem) \{\par
            $selectedCityRaw = $script:UIControls.cbCity.SelectedItem.ToString()\par
            $selectedCity = $selectedCityRaw -replace "\f1\u11088?\f0  ", ""\par
        \}\par
        \par
        if ([string]::IsNullOrWhiteSpace($selectedCity)) \{\par
            $script:UIControls.lbComputers.Items.Add("Veuillez s\'e9lectionner une ville")\par
            $script:UIControls.grpComputers.Text = "PC sans N\'b0 s\'e9rie - Aucune ville"\par
            return\par
        \}\par
        \par
        $searchBase = "OU=$selectedCity,$($script:Config.BaseOU)"\par
        \par
        try \{\par
            $null = Get-ADOrganizationalUnit -Identity $searchBase -ErrorAction Stop\par
        \} catch \{\par
            $script:UIControls.lbComputers.Items.Add("Ville introuvable : $selectedCity")\par
            $script:UIControls.grpComputers.Text = "PC sans N\'b0 s\'e9rie - Erreur"\par
            return\par
        \}\par
        \par
        # Recherche am\'e9lior\'e9e avec d\'e9tection des num\'e9ros de s\'e9rie invalides\par
        $computers = Get-ADComputer -SearchBase $searchBase -Filter "Enabled -eq 'True'" -Properties Name, SerialNumber, Description, OperatingSystem, LastLogonDate |\par
                    Where-Object \{ \par
                        [string]::IsNullOrWhiteSpace($_.SerialNumber) -or \par
                        $_.SerialNumber -eq "To be filled by O.E.M." -or \par
                        $_.SerialNumber -eq "Default string" -or \par
                        $_.SerialNumber -eq "System Serial Number" -or\par
                        $_.SerialNumber -eq "Not Specified" -or\par
                        $_.SerialNumber -eq "0" -or\par
                        $_.SerialNumber.Length -lt 3\par
                    \} |\par
                    Sort-Object Name |\par
                    Select-Object -First 100\par
        \par
        if ($computers.Count -eq 0) \{\par
            $script:UIControls.lbComputers.Items.Add("Tous les PC ont un N\'b0 s\'e9rie valide")\par
        \} else \{\par
            foreach ($computer in $computers) \{\par
                $displayName = $computer.Name\par
                \par
                if (-not [string]::IsNullOrWhiteSpace($computer.OperatingSystem)) \{\par
                    $osShort = $computer.OperatingSystem -replace "Microsoft Windows ", "Win"\par
                    $displayName += " [$osShort]"\par
                \}\par
                \par
                if ($computer.LastLogonDate -and $computer.LastLogonDate -gt (Get-Date).AddDays(-7)) \{\par
                    $displayName += " [RECENT]"\par
                \} else \{\par
                    $displayName += " [ACTIF]"\par
                \}\par
                \par
                $script:UIControls.lbComputers.Items.Add($displayName)\par
            \}\par
        \}\par
        \par
        $timestamp = Get-Date -Format "HH:mm:ss"\par
        $script:UIControls.grpComputers.Text = "PC sans N\'b0 s\'e9rie - $selectedCity ($($computers.Count)) - $timestamp"\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors du chargement des ordinateurs: $($_.Exception.Message)" -Level Error\par
        $script:UIControls.lbComputers.Items.Clear()\par
        $script:UIControls.lbComputers.Items.Add("Erreur de chargement")\par
    \}\par
\}\par
