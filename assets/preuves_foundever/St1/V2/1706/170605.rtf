# Fonction pour g\'e9rer les valeurs nulles\par
function Get-ValueOrDefault \{\par
    param(\par
        [Parameter(ValueFromPipeline)]\par
        $Value,\par
        [string]$Default = ""\par
    )\par
    \par
    if ($null -eq $Value -or [string]::IsNullOrWhiteSpace($Value)) \{\par
        return $Default\par
    \}\par
    return $Value.ToString()\par
\}\par
