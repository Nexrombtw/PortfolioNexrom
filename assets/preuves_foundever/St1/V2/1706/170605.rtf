# Mise \'e0 jour du num\'e9ro de s\'e9rie dans AD avec rafra\'eechissement imm\'e9diat\par
function Update-ComputerSerialInAD \{\par
    param(\par
        [string]$ComputerName,\par
        [string]$SerialNumber\par
    )\par
    \par
    try \{\par
        # V\'e9rifier que l'ordinateur existe\par
        $computer = Get-ADComputer -Identity $ComputerName -ErrorAction Stop\par
        \par
        $confirmMessage = "Mettre \'e0 jour le num\'e9ro de s\'e9rie ?`n`n" +\par
                         "Ordinateur : $ComputerName`n" +\par
                         "Nouveau num\'e9ro de s\'e9rie : $SerialNumber`n`n" +\par
                         "Cette action remplacera le num\'e9ro de s\'e9rie existant."\par
        \par
        if (-not (Show-ConfirmDialog $confirmMessage "Confirmation de mise \'e0 jour")) \{\par
            return\par
        \}\par
        \par
        # REMPLACER le num\'e9ro de s\'e9rie existant\par
        Set-ADComputer -Identity $ComputerName -Replace @\{SerialNumber = $SerialNumber\} -ErrorAction Stop\par
        \par
        Write-Log "Num\'e9ro de s\'e9rie mis \'e0 jour pour $ComputerName : $SerialNumber" -Level Info\par
        \par
        Show-InfoMessage "Num\'e9ro de s\'e9rie mis \'e0 jour avec succ\'e8s !`n`nOrdinateur : $ComputerName`nNum\'e9ro de s\'e9rie : $SerialNumber" "Mise \'e0 jour r\'e9ussie"\par
        \par
