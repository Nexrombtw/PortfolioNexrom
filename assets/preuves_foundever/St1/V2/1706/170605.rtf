# Ex\'e9cution du d\'e9placement avec style uniforme\par
function Execute-UniformUserMove \{\par
    param(\par
        [Microsoft.ActiveDirectory.Management.ADUser]$User,\par
        [string]$TargetPath,\par
        [string]$DisplayName,\par
        [System.Windows.Forms.Form]$ParentForm\par
    )\par
    \par
    try \{\par
        $confirmMessage = "CONFIRMATION DE D\'c9PLACEMENT`n`n" +\par
                         "Utilisateur : $($User.GivenName) $($User.Surname) [$($User.SamAccountName)]`n`n" +\par
                         "DEPUIS :`n$($User.DistinguishedName)`n`n" +\par
                         "VERS :`n$TargetPath`n`n" +\par
                         "Dossier de destination : $DisplayName`n`n" +\par
                         "Cette action est irr\'e9versible. Continuer ?"\par
        \par
        if (Show-ConfirmDialog $confirmMessage "Confirmation de d\'e9placement") \{\par
            # NOUVEAU : Sauvegarder la description actuelle avant le d\'e9placement\par
            $currentUser = Get-ADUser -Identity $User.SamAccountName -Properties Description -ErrorAction Stop\par
            $originalDescription = $currentUser.Description\par
            \par
            # Ex\'e9cution du d\'e9placement\par
            Move-ADObject -Identity $User.DistinguishedName -TargetPath $TargetPath -ErrorAction Stop\par
            \par
                    # NOUVEAU : Restaurer la description originale apr\'e8s le d\'e9placement\par
            if (-not [string]::IsNullOrEmpty($originalDescription)) \{\par
                Set-ADUser -Identity $User.SamAccountName -Description $originalDescription -ErrorAction SilentlyContinue\par
                Write-Log "Description originale restaur\'e9e pour $($User.SamAccountName): $originalDescription" -Level Debug\par
            \}\par
            \par
            Write-Log "Utilisateur $($User.SamAccountName) d\'e9plac\'e9 avec succ\'e8s vers $TargetPath (description pr\'e9serv\'e9e)" -Level Info\par
            \par
            $successMessage = "D\'c9PLACEMENT R\'c9USSI`n`n" +\par
                             "L'utilisateur $($User.GivenName) $($User.Surname) a \'e9t\'e9 d\'e9plac\'e9 avec succ\'e8s.`n`n" +\par
                             "Nouveau dossier : $DisplayName`n" +\par
                             "Nouveau chemin : $TargetPath`n`n" +\par
                             "Description AD pr\'e9serv\'e9e`n`n" +\par
                             "D\'e9placement effectu\'e9 le : $(Get-Date -Format "dd/MM/yyyy \'e0 HH:mm:ss")`n" +\par
                             "Par : $env:USERNAME"\par
            \par
            Show-InfoMessage $successMessage "D\'e9placement r\'e9ussi"\par
            \par
            # Fermeture du formulaire et rafra\'eechissement\par
            $ParentForm.Close()\par
            Show-UserDetails\par
        \}\par
    \} catch \{\par
        Write-Log "Erreur lors du d\'e9placement: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de d\'e9placement" "Impossible de d\'e9placer l'utilisateur :`n$($_.Exception.Message)"\par
    \}\par
\}\par
