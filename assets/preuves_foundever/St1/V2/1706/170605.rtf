# Gestion des param\'e8tres avec validation\par
function Load-FavoriteCity \{\par
    try \{\par
        if (Test-Path $script:Config.SettingsPath) \{\par
            $json = Get-Content $script:Config.SettingsPath -Raw -ErrorAction Stop | ConvertFrom-Json -ErrorAction Stop\par
            if ($json.PSObject.Properties.Name -contains 'FavoriteCity') \{\par
                Write-Log "Ville favorite charg\'e9e: $($json.FavoriteCity)" -Level Debug\par
                return $json.FavoriteCity\par
            \}\par
        \}\par
    \} catch \{\par
        Write-Log "Erreur lors du chargement de la ville favorite: $($_.Exception.Message)" -Level Warning\par
    \}\par
    return $null\par
\}\par
\par
function Save-FavoriteCity \{\par
    param([string]$City)\par
    \par
    $cleanCity = $City -replace "\f1\u11088?\f0  ", ""\par
    \par
    if ([string]::IsNullOrWhiteSpace($cleanCity)) \{\par
        Write-Log "Tentative de sauvegarde d'une ville vide" -Level Warning\par
        return\par
    \}\par
    \par
    try \{\par
        $settings = @\{ FavoriteCity = $cleanCity \}\par
        $settings | ConvertTo-Json | Set-Content $script:Config.SettingsPath -ErrorAction Stop\par
        Write-Log "Ville favorite sauvegard\'e9e: $cleanCity" -Level Info\par
        \par
        $currentSelection = $script:UIControls.cbCity.SelectedItem\par
        Load-Cities\par
        \par
        $favoriteWithStar = "\f1\u11088?\f0  $cleanCity"\par
        if ($script:UIControls.cbCity.Items.Contains($favoriteWithStar)) \{\par
            $script:UIControls.cbCity.SelectedItem = $favoriteWithStar\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la sauvegarde de la ville favorite: $($_.Exception.Message)" -Level Error\par
    \}\par
\}\par
