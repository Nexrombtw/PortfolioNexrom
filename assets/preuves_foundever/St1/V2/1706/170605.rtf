# Recherche de groupes dans tout l'AD\par
function Search-ADGroups \{\par
    try \{\par
        $searchTerm = $script:UIControls.txtGroupSearch.Text.Trim()\par
        \par
        if ([string]::IsNullOrWhiteSpace($searchTerm) -or $searchTerm -eq "Rechercher un groupe...") \{\par
            Show-InfoMessage "Veuillez saisir un terme de recherche pour les groupes."\par
            return\par
        \}\par
        \par
        if ($searchTerm.Length -lt 3) \{\par
            Show-InfoMessage "Veuillez saisir au moins 3 caract\'e8res pour la recherche."\par
            return\par
        \}\par
        \par
        $groups = Get-ADGroup -Filter "Name -like '*$searchTerm*'" -Properties Name, Description | \par
                  Sort-Object Name | \par
                  Select-Object -First 50\par
        \par
        if ($groups.Count -eq 0) \{\par
            Show-InfoMessage "Aucun groupe trouv\'e9 avec le terme '$searchTerm'."\par
            return\par
        \}\par
        \par
        # Fen\'eatre de s\'e9lection\par
        $groupSelectionForm = New-Object System.Windows.Forms.Form -Property @\{\par
            Text = "S\'e9lectionner un groupe"\par
            Size = [System.Drawing.Size]::new(500, 400)\par
            StartPosition = "CenterParent"\par
            FormBorderStyle = 'FixedDialog'\par
            MaximizeBox = $false\par
            MinimizeBox = $false\par
            BackColor = $script:Theme.Background\par
        \}\par
        \par
        $groupListBox = New-Object System.Windows.Forms.ListBox -Property @\{\par
            Location = [System.Drawing.Point]::new(20, 20)\par
            Size = [System.Drawing.Size]::new(440, 280)\par
            Font = [System.Drawing.Font]::new("Segoe UI", 9)\par
            BackColor = $script:Theme.White\par
            ForeColor = $script:Theme.Text\par
        \}\par
        \par
        foreach ($group in $groups) \{\par
            $displayName = if ($group.Description) \{\par
                "$($group.Name) - $($group.Description)"\par
            \} else \{\par
                $group.Name\par
            \}\par
            $groupListBox.Items.Add($displayName)\par
        \}\par
        \par
        $btnSelect = New-Object System.Windows.Forms.Button -Property @\{\par
            Text = "Ajouter au groupe"\par
            Location = [System.Drawing.Point]::new(280, 320)\par
            Size = [System.Drawing.Size]::new(120, 30)\par
            BackColor = $script:Theme.ButtonPrimary\par
            ForeColor = $script:Theme.White\par
            FlatStyle = 'Flat'\par
        \}\par
        \par
        $btnCancel = New-Object System.Windows.Forms.Button -Property @\{\par
            Text = "Annuler"\par
            Location = [System.Drawing.Point]::new(410, 320)\par
            Size = [System.Drawing.Size]::new(70, 30)\par
            BackColor = $script:Theme.ButtonSecondary\par
            ForeColor = $script:Theme.White\par
            FlatStyle = 'Flat'\par
        \}\par
        \par
        $btnSelect.Add_Click(\{\par
            if ($groupListBox.SelectedItem) \{\par
                $selectedGroup = $groupListBox.SelectedItem.ToString()\par
                if ($selectedGroup -match '^([^-]+)') \{\par
                    $groupName = $matches[1].Trim()\par
                \} else \{\par
                    $groupName = $selectedGroup\par
                \}\par
                try \{\par
                    Add-UserToSelectedGroup $groupName\par
                    $groupSelectionForm.Close()\par
                \} catch \{\par
                    Show-ErrorMessage "Erreur lors de l'ajout au groupe" $_.Exception.Message\par
                \}\par
            \} else \{\par
                Show-InfoMessage "Veuillez s\'e9lectionner un groupe."\par
            \}\par
        \})\par
        \par
        $btnCancel.Add_Click(\{\par
            $groupSelectionForm.Close()\par
        \})\par
        \par
        $groupSelectionForm.Controls.AddRange(@($groupListBox, $btnSelect, $btnCancel))\par
        $groupSelectionForm.ShowDialog()\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la recherche de groupes: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de recherche" "Impossible de rechercher les groupes: $($_.Exception.Message)"\par
    \}\par
\}\par
