# Fonction pour ajouter un utilisateur au groupe s\'e9lectionn\'e9\par
function Add-UserToSelectedGroup \{\par
    param([string]$GroupName)\par
    \par
    if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
        Show-InfoMessage "Veuillez s\'e9lectionner un utilisateur."\par
        return\par
    \}\par
    \par
    $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
    if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
        $samAccountName = $matches[1]\par
    \} else \{\par
        Show-ErrorMessage "Erreur de s\'e9lection" "Impossible d'identifier l'utilisateur s\'e9lectionn\'e9."\par
        return\par
    \}\par
    \par
    try \{\par
        $currentGroups = Get-ADPrincipalGroupMembership -Identity $samAccountName | Select-Object -ExpandProperty Name\par
        if ($currentGroups -contains $GroupName) \{\par
            Show-InfoMessage "L'utilisateur est d\'e9j\'e0 membre du groupe '$GroupName'."\par
            return\par
        \}\par
        \par
        if (-not (Show-ConfirmDialog "Ajouter $samAccountName au groupe '$GroupName' ?" "Confirmation d'ajout")) \{\par
            return\par
        \}\par
        \par
        Add-ADGroupMember -Identity $GroupName -Members $samAccountName\par
        Write-Log "Utilisateur $samAccountName ajout\'e9 au groupe $GroupName" -Level Info\par
        \par
        Show-InfoMessage "Utilisateur ajout\'e9 au groupe '$GroupName' avec succ\'e8s !"\par
        Show-UserDetails\par
    \} catch \{\par
        Write-Log "Erreur lors de l'ajout au groupe: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur d'ajout" "Impossible d'ajouter l'utilisateur au groupe: $($_.Exception.Message)"\par
    \}\par
\}\par
\par
# Suppression d'utilisateur d'un groupe\par
function Remove-UserFromGroup \{\par
    try \{\par
        if (-not $script:UIControls.lbUsers.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un utilisateur."\par
            return\par
        \}\par
        \par
        if (-not $script:UIControls.lbGrps.SelectedItem) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner un groupe dans la liste des appartenances."\par
            return\par
        \}\par
        \par
        $selectedText = $script:UIControls.lbUsers.SelectedItem.ToString()\par
        if ($selectedText -match '\\[([^\\]]+)\\]') \{\par
            $samAccountName = $matches[1]\par
        \} else \{\par
            Show-ErrorMessage "Erreur de s\'e9lection" "Impossible d'identifier l'utilisateur s\'e9lectionn\'e9."\par
            return\par
        \}\par
        \par
        $groupName = $script:UIControls.lbGrps.SelectedItem.ToString()\par
        \par
        if ($groupName -eq "Domain Users") \{\par
            Show-ErrorMessage "Action interdite" "Impossible de retirer un utilisateur du groupe 'Domain Users'."\par
            return\par
        \}\par
        \par
        if (-not (Show-ConfirmDialog "Retirer $samAccountName du groupe '$groupName' ?" "Confirmation de suppression")) \{\par
            return\par
        \}\par
        \par
        Remove-ADGroupMember -Identity $groupName -Members $samAccountName -Confirm:$false\par
        Write-Log "Utilisateur $samAccountName retir\'e9 du groupe $groupName" -Level Info\par
        \par
        Show-InfoMessage "Utilisateur retir\'e9 du groupe '$groupName' avec succ\'e8s !"\par
        Show-UserDetails\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la suppression du groupe: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de suppression" "Impossible de retirer l'utilisateur du groupe: $($_.Exception.Message)"\par
    \}\par
\}\par
