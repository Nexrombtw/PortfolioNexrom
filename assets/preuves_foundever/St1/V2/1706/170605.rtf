# Syst\'e8me de logging avanc\'e9\par
function Write-Log \{\par
    param(\par
        [string]$Message,\par
        [ValidateSet('Info', 'Warning', 'Error', 'Debug')]\par
        [string]$Level = 'Info'\par
    )\par
    \par
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"\par
    $logEntry = "[$timestamp] [$Level] $Message"\par
    \par
    try \{\par
        Add-Content -Path $script:Config.LogPath -Value $logEntry -ErrorAction SilentlyContinue\par
    \} catch \{\par
        # Fallback si impossible d'\'e9crire dans le log\par
    \}\par
    \par
    # Affichage console selon le niveau\par
    switch ($Level) \{\par
        'Error' \{ Write-Host $logEntry -ForegroundColor Red \}\par
        'Warning' \{ Write-Host $logEntry -ForegroundColor Yellow \}\par
        'Info' \{ Write-Host $logEntry -ForegroundColor Green \}\par
        'Debug' \{ Write-Host $logEntry -ForegroundColor Cyan \}\par
    \}\par
\}\par
