# NOUVELLE FONCTION : Recherche de groupes pour gestion en lot\par
function Search-BulkGroups \{\par
    param(\par
        [string]$SearchTerm,\par
        [System.Windows.Forms.ListBox]$GroupList\par
    )\par
    \par
    try \{\par
        $GroupList.Items.Clear()\par
        \par
        if ([string]::IsNullOrWhiteSpace($SearchTerm) -or $SearchTerm.Length -lt 3) \{\par
            Show-InfoMessage "Veuillez saisir au moins 3 caract\'e8res pour la recherche de groupes."\par
            return\par
        \}\par
        \par
        $groups = Get-ADGroup -Filter "Name -like '*$SearchTerm*'" -Properties Name, Description | \par
                  Sort-Object Name | \par
                  Select-Object -First 50\par
        \par
        foreach ($group in $groups) \{\par
            $displayName = if ($group.Description) \{\par
                "$($group.Name) - $($group.Description)"\par
            \} else \{\par
                $group.Name\par
            \}\par
            $GroupList.Items.Add($displayName)\par
        \}\par
        \par
        Write-Log "Recherche de groupes : $($groups.Count) groupes trouv\'e9s pour '$SearchTerm'" -Level Info\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la recherche de groupes: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de recherche" "Impossible de rechercher les groupes: $($_.Exception.Message)"\par
    \}\par
\}\par
