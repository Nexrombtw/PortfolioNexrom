        \}\par
        \par
        if (-not (Initialize-MainForm)) \{ return $false \}\par
        if (-not (Initialize-SearchControls)) \{ return $false \}\par
        if (-not (Initialize-UserList)) \{ return $false \}\par
        if (-not (Initialize-ComputersPanel)) \{ return $false \}  \par
