# NOUVELLE FONCTION : Auto-d\'e9tection simple des num\'e9ros de s\'e9rie\par
function Start-SimpleAutoSerial \{\par
    try \{\par
        if (-not (Show-ConfirmDialog "R\'e9cup\'e9rer automatiquement les num\'e9ros de s\'e9rie des PC connect\'e9s r\'e9cemment ?`n`nCela peut prendre quelques minutes." "Auto-d\'e9tection")) \{\par
            return\par
        \}\par
        \par
        $selectedCity = ""\par
        if ($script:UIControls.cbCity.SelectedItem) \{\par
            $selectedCityRaw = $script:UIControls.cbCity.SelectedItem.ToString()\par
            $selectedCity = $selectedCityRaw -replace "\f1\u11088?\f0  ", ""\par
        \}\par
        \par
        if ([string]::IsNullOrWhiteSpace($selectedCity)) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner une ville."\par
            return\par
        \}\par
        \par
        $searchBase = "OU=$selectedCity,$($script:Config.BaseOU)"\par
        \par
        $computers = Get-ADComputer -SearchBase $searchBase -Filter "Enabled -eq 'True'" -Properties Name, SerialNumber, LastLogonDate |\par
                    Where-Object \{ \par
                        $_.LastLogonDate -gt (Get-Date).AddDays(-3) -and\par
                        ([string]::IsNullOrWhiteSpace($_.SerialNumber) -or $_.SerialNumber -eq "To be filled by O.E.M.")\par
                    \} |\par
                    Select-Object -First 10\par
        \par
        if ($computers.Count -eq 0) \{\par
            Show-InfoMessage "Aucun ordinateur \'e9ligible trouv\'e9."\par
            return\par
        \}\par
        \par
        $results = @()\par
        $successCount = 0\par
        \par
        foreach ($computer in $computers) \{\par
            try \{\par
                if (Test-Connection -ComputerName $computer.Name -Count 1 -Quiet -ErrorAction SilentlyContinue) \{\par
                    $serialNumber = (Get-CimInstance -ComputerName $computer.Name -ClassName Win32_BIOS -ErrorAction Stop).SerialNumber\par
                    \par
                    if (-not [string]::IsNullOrWhiteSpace($serialNumber) -and $serialNumber -ne "To be filled by O.E.M." -and $serialNumber.Length -ge 3) \{\par
                        Set-ADComputer -Identity $computer.Name -Replace @\{SerialNumber = $serialNumber\} -ErrorAction Stop\par
                        $results += "SUCCES - $($computer.Name) : $serialNumber"\par
                        $successCount++\par
                    \} else \{\par
                        $results += "ECHEC - $($computer.Name) : N\'b0 s\'e9rie invalide"\par
                    \}\par
                \} else \{\par
                    $results += "ECHEC - $($computer.Name) : Non accessible"\par
                \}\par
            \} catch \{\par
                $results += "ERREUR - $($computer.Name) : $($_.Exception.Message)"\par
            \}\par
        \}\par
        \par
        $resultMessage = "AUTO-D\'c9TECTION TERMIN\'c9E`n`n" +\par
                        "Ordinateurs trait\'e9s : $($computers.Count)`n" +\par
                        "Succ\'e8s : $successCount`n`n" +\par
                        ($results -join "`n")\par
        \par
        Show-InfoMessage $resultMessage "R\'e9sultats"\par
        Load-ComputersWithoutSerial\par
        \par
    \} catch \{\par
        Show-ErrorMessage "Erreur" $_.Exception.Message\par
    \}\par
\}\par
# NOUVELLE FONCTION : Export simple\par
function Export-SimpleComputerList \{\par
    try \{\par
        $selectedCity = ""\par
        if ($script:UIControls.cbCity.SelectedItem) \{\par
            $selectedCityRaw = $script:UIControls.cbCity.SelectedItem.ToString()\par
            $selectedCity = $selectedCityRaw -replace "\f1\u11088?\f0  ", ""\par
        \}\par
        \par
        if ([string]::IsNullOrWhiteSpace($selectedCity)) \{\par
            Show-InfoMessage "Veuillez s\'e9lectionner une ville."\par
            return\par
        \}\par
        \par
        $saveDialog = New-Object System.Windows.Forms.SaveFileDialog -Property @\{\par
            Filter = "Fichiers CSV (*.csv)|*.csv"\par
            FileName = "PC_$selectedCity`_$(Get-Date -Format 'yyyyMMdd').csv"\par
        \}\par
        \par
        if ($saveDialog.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) \{\par
            $searchBase = "OU=$selectedCity,$($script:Config.BaseOU)"\par
            $computers = Get-ADComputer -SearchBase $searchBase -Filter * -Properties Name, SerialNumber, OperatingSystem, Enabled, LastLogonDate\par
            \par
            $csvData = @("Nom,Num\'e9ro de s\'e9rie,\'c9tat,Derni\'e8re connexion,Ville")\par
            \par
            foreach ($computer in $computers) \{\par
                $serial = if ([string]::IsNullOrWhiteSpace($computer.SerialNumber)) \{ "Non d\'e9fini" \} else \{ $computer.SerialNumber \}\par
                $os = if ([string]::IsNullOrWhiteSpace($computer.OperatingSystem)) \{ "Inconnu" \} else \{ $computer.OperatingSystem \}\par
                $state = if ($computer.Enabled) \{ "Actif" \} else \{ "Inactif" \}\par
                $lastLogon = if ($computer.LastLogonDate) \{ $computer.LastLogonDate.ToString("dd/MM/yyyy") \} else \{ "Jamais" \}\par
                \par
                $csvData += "$($computer.Name),$serial,$os,$state,$lastLogon,$selectedCity"\par
            \}\par
            \par
            $csvData | Out-File -FilePath $saveDialog.FileName -Encoding UTF8\par
            Show-InfoMessage "Export r\'e9ussi : $($saveDialog.FileName)" "Export termin\'e9"\par
        \}\par
    \} catch \{\par
        Show-ErrorMessage "Erreur d'export" $_.Exception.Message\par
    \}\par
\}\par
\par
# NOUVELLE FONCTION : R\'e9cup\'e9ration automatique du num\'e9ro de s\'e9rie\par
function Get-RemoteSerialNumber \{\par
    param([string]$ComputerName)\par
    \par
    try \{\par
        if (Test-Connection -ComputerName $ComputerName -Count 1 -Quiet -ErrorAction SilentlyContinue) \{\par
            $serialNumber = (Get-CimInstance -ComputerName $ComputerName -ClassName Win32_BIOS -ErrorAction Stop).SerialNumber\par
            \par
            if (-not [string]::IsNullOrWhiteSpace($serialNumber) -and $serialNumber -ne "To be filled by O.E.M." -and $serialNumber.Length -ge 3) \{\par
                Set-ADComputer -Identity $ComputerName -Replace @\{SerialNumber = $serialNumber\} -ErrorAction Stop\par
                Show-InfoMessage "Num\'e9ro de s\'e9rie r\'e9cup\'e9r\'e9 : $ComputerName : $serialNumber" "Succ\'e8s"\par
                Load-ComputersWithoutSerial\par
            \} else \{\par
                Show-InfoMessage "Le num\'e9ro de s\'e9rie r\'e9cup\'e9r\'e9 n'est pas valide : $serialNumber" "Attention"\par
            \}\par
        \} else \{\par
            Show-InfoMessage "L'ordinateur $ComputerName n'est pas accessible." "Erreur"\par
        \}\par
    \} catch \{\par
        Show-ErrorMessage "Erreur" "Impossible de r\'e9cup\'e9rer le num\'e9ro de s\'e9rie : $($_.Exception.Message)"\par
    \}\par
\}\par
\par
