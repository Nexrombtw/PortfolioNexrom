# NOUVELLE FONCTION : Recherche d'utilisateurs pour gestion en lot\par
function Search-BulkUsers \{\par
    param(\par
        [string]$SearchTerm,\par
        [System.Windows.Forms.CheckedListBox]$UserList,\par
        [System.Windows.Forms.Label]$CountLabel\par
    )\par
    \par
    try \{\par
        $UserList.Items.Clear()\par
        \par
        if ([string]::IsNullOrWhiteSpace($SearchTerm) -or $SearchTerm.Length -lt 2) \{\par
            Show-InfoMessage "Veuillez saisir au moins 2 caract\'e8res pour la recherche."\par
            return\par
        \}\par
        \par
        # Recherche dans toutes les villes\par
        $allUsers = @()\par
        $cities = @()\par
        \par
        # R\'e9cup\'e9ration des villes\par
        $root = New-Object System.DirectoryServices.DirectoryEntry("LDAP://$($script:Config.BaseOU)")\par
        $searcher = New-Object System.DirectoryServices.DirectorySearcher($root)\par
        $searcher.Filter = "(objectCategory=organizationalUnit)"\par
        $searcher.SearchScope = [System.DirectoryServices.SearchScope]::OneLevel\par
        $searcher.PropertiesToLoad.Add("ou") | Out-Null\par
        \par
        $cities = $searcher.FindAll() | ForEach-Object \{\par
            if ($_.Properties["ou"].Count -gt 0) \{ \par
                $_.Properties["ou"][0] \par
            \}\par
        \}\par
        \par
        # Recherche dans chaque ville\par
        foreach ($city in $cities) \{\par
            try \{\par
                $searchBase = "OU=$city,$($script:Config.BaseOU)"\par
                $users = Get-ADUser -SearchBase $searchBase -Filter "GivenName -like '*$SearchTerm*' -or Surname -like '*$SearchTerm*' -or SamAccountName -like '*$SearchTerm*'" -Properties GivenName, Surname, SamAccountName, Enabled, Department |\par
                         Where-Object \{ $_.Enabled -eq $true \} |\par
                         Select-Object -First 20\par
                \par
                foreach ($user in $users) \{\par
                    $displayName = "$($user.Surname) $($user.GivenName) [$($user.SamAccountName)] - $city"\par
                    if ($user.Department) \{\par
                        $displayName += " ($($user.Department))"\par
                    \}\par
                    $allUsers += $displayName\par
                \}\par
            \} catch \{\par
                Write-Log "Erreur recherche dans $city : $($_.Exception.Message)" -Level Warning\par
            \}\par
        \}\par
        \par
        # Tri et ajout \'e0 la liste\par
        $allUsers = $allUsers | Sort-Object | Select-Object -First 100\par
        \par
        foreach ($user in $allUsers) \{\par
            $UserList.Items.Add($user)\par
        \}\par
        \par
        $CountLabel.Text = "$($allUsers.Count) utilisateur(s) trouv\'e9(s)"\par
        Write-Log "Recherche en lot : $($allUsers.Count) utilisateurs trouv\'e9s pour '$SearchTerm'" -Level Info\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la recherche d'utilisateurs en lot: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de recherche" "Impossible de rechercher les utilisateurs: $($_.Exception.Message)"\par
    \}\par
\}\par
