# Recherche avec affichage "Nom Pr\'e9nom"\par
function Refresh-Users \{\par
    try \{\par
        $script:UIControls.lbUsers.Items.Clear()\par
        Clear-UserDetails\par
        \par
        if (-not $script:UIControls.cbCity.SelectedItem) \{\par
            Write-Log "Aucune ville s\'e9lectionn\'e9e" -Level Warning\par
            return\par
        \}\par
        \par
        $selectedCityRaw = $script:UIControls.cbCity.SelectedItem.ToString()\par
        $selectedCity = $selectedCityRaw -replace "\f1\u11088?\f0  ", ""\par
        \par
        $searchTerm = $script:UIControls.txtSearch.Text.Trim()\par
        \par
        if ([string]::IsNullOrWhiteSpace($searchTerm) -or $searchTerm -eq "Saisir un terme de recherche...") \{\par
            Write-Log "Aucun terme de recherche - liste vide maintenue" -Level Info\par
            return\par
        \}\par
        \par
        if ($searchTerm.Length -lt 2) \{\par
            Show-InfoMessage "Veuillez saisir au moins 2 caract\'e8res pour effectuer une recherche."\par
            return\par
        \}\par
        \par
        $searchBase = "OU=$selectedCity,$($script:Config.BaseOU)"\par
        \par
        try \{\par
            $null = Get-ADOrganizationalUnit -Identity $searchBase -ErrorAction Stop\par
        \} catch \{\par
            Show-ErrorMessage "OU introuvable" "L'unit\'e9 organisationnelle '$searchBase' n'existe pas."\par
            return\par
        \}\par
        \par
        Write-Log "Recherche dans $searchBase avec terme: '$searchTerm'" -Level Debug\par
        \par
        $users = Get-ADUser -SearchBase $searchBase -Filter "GivenName -like '*$searchTerm*' -or Surname -like '*$searchTerm*' -or SamAccountName -like '*$searchTerm*' -or DisplayName -like '*$searchTerm*'" -Properties Name, SamAccountName, Enabled, Department, GivenName, Surname, DisplayName |\par
                 Sort-Object Surname, GivenName |\par
                 Select-Object -First 500\par
        \par
        foreach ($user in $users) \{\par
            # Affichage "Nom Pr\'e9nom" au lieu de "Pr\'e9nom Nom"\par
            $displayName = "$($user.Surname) $($user.GivenName) [$($user.SamAccountName)]"\par
            \par
            if (-not $user.Enabled) \{\par
                $displayName += " [D\'c9SACTIV\'c9]"\par
            \}\par
            \par
            if ($user.Department) \{\par
                $displayName += " - $($user.Department)"\par
            \}\par
            $script:UIControls.lbUsers.Items.Add($displayName)\par
        \}\par
        \par
        Write-Log "Trouv\'e9 $($users.Count) utilisateurs correspondant \'e0 '$searchTerm'" -Level Info\par
        \par
        if ($users.Count -eq 0) \{\par
            Show-InfoMessage "Aucun utilisateur trouv\'e9 avec le terme de recherche '$searchTerm'."\par
        \} elseif ($users.Count -eq 500) \{\par
            Show-InfoMessage "Plus de 500 r\'e9sultats trouv\'e9s. Seuls les 500 premiers sont affich\'e9s. Affinez votre recherche."\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la recherche d'utilisateurs: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur de recherche" "Impossible de rechercher les utilisateurs: $($_.Exception.Message)"\par
    \}\par
\}\par
