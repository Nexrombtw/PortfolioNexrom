# G\'e9n\'e9ration s\'e9curis\'e9e de mot de passe\par
function New-SecurePassword \{\par
    param([string]$EmployeeID)\par
    \par
    if ([string]::IsNullOrWhiteSpace($EmployeeID)) \{\par
        throw "ID employ\'e9 requis pour g\'e9n\'e9rer le mot de passe"\par
    \}\par
    \par
    $randomNumbers = -join ((0..9) | Get-Random -Count 6)\par
    $specialChars = @('!', '@', '#', '$', '%', '&', '*')\par
    $specialChar = $specialChars | Get-Random\par
    \par
    return "Foundever@$EmployeeID$specialChar$randomNumbers"\par
\}\par
