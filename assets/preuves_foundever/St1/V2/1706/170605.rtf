# Fonction pour charger les villes avec style uniforme\par
function Load-AvailableCitiesForMove \{\par
    param([System.Windows.Forms.ComboBox]$ComboBox)\par
    \par
    try \{\par
        $ComboBox.Items.Clear()\par
        \par
        # R\'e9cup\'e9ration des villes depuis AD\par
        $root = New-Object System.DirectoryServices.DirectoryEntry("LDAP://$($script:Config.BaseOU)")\par
        $searcher = New-Object System.DirectoryServices.DirectorySearcher($root)\par
        $searcher.Filter = "(objectCategory=organizationalUnit)"\par
        $searcher.SearchScope = [System.DirectoryServices.SearchScope]::OneLevel\par
        $searcher.PropertiesToLoad.Add("ou") | Out-Null\par
        \par
        $cities = $searcher.FindAll() | ForEach-Object \{\par
            if ($_.Properties["ou"].Count -gt 0) \{ \par
                $_.Properties["ou"][0] \par
            \}\par
        \} | Sort-Object | Select-Object -Unique\par
        \par
        # R\'e9cup\'e9ration de la ville favorite\par
        $favoriteCity = Load-FavoriteCity\par
        \par
        # Ajout de la ville favorite en premier\par
        if ($favoriteCity -and $cities -contains $favoriteCity) \{\par
            $ComboBox.Items.Add("\f1\u11088?\f0  $favoriteCity")\par
        \}\par
        \par
        # Ajout des autres villes\par
        foreach ($city in $cities) \{\par
            if ($city -ne $favoriteCity) \{\par
                $ComboBox.Items.Add($city)\par
            \}\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors du chargement des villes: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur" "Impossible de charger la liste des villes: $($_.Exception.Message)"\par
    \}\par
\}\par
