# Fonction pour charger les dossiers avec style uniforme\par
function Load-UniformCityFolders \{\par
    param(\par
        [string]$SelectedCity,\par
        [System.Windows.Forms.TreeView]$TreeView,\par
        [System.Windows.Forms.Label]$InfoLabel,\par
        [string]$CurrentUserPath\par
    )\par
    \par
    try \{\par
        $TreeView.BeginUpdate()\par
        $TreeView.Nodes.Clear()\par
        \par
        $cityBasePath = "OU=$SelectedCity,$($script:Config.BaseOU)"\par
        \par
        # Dossiers \'e0 exclure pour une interface claire\par
        $excludedFolders = @(\par
            "Groups", "Functions", "Computers", "Service Accounts", \par
            "Resources", "Contacts", "Distribution Lists", "Security Groups",\par
            "Shared Mailboxes", "Room Mailboxes", "Equipment", "Templates",\par
            "System", "Builtin", "ForeignSecurityPrincipals", "Managed Service Accounts"\par
        )\par
        \par
        # R\'e9cup\'e9ration des dossiers utilisateur\par
        $userOUs = Get-ADOrganizationalUnit -SearchBase $cityBasePath -SearchScope Subtree -Filter * |\par
                   Where-Object \{ $excludedFolders -notcontains $_.Name \} |\par
                   Sort-Object DistinguishedName\par
        \par
        if ($userOUs.Count -eq 0) \{\par
            $noFolderNode = $TreeView.Nodes.Add("Aucun dossier utilisateur disponible")\par
            $noFolderNode.Tag = $null\par
            $InfoLabel.Text = "Aucun dossier trouv\'e9 dans cette ville"\par
            return\par
        \}\par
        \par
        # Organisation hi\'e9rarchique des dossiers\par
        $folderDict = @\{\}\par
        foreach ($ou in $userOUs) \{\par
            $parentDN = ($ou.DistinguishedName -split ',', 2)[1]\par
            if (-not $folderDict.ContainsKey($parentDN)) \{\par
                $folderDict[$parentDN] = @()\par
            \}\par
            $folderDict[$parentDN] += $ou\par
        \}\par
        \par
        # Construction de l'arbre avec noms clairs\par
        Build-UniformFolderTree $TreeView $null $cityBasePath $folderDict $CurrentUserPath\par
        \par
        # Expansion automatique du premier niveau\par
        foreach ($node in $TreeView.Nodes) \{\par
            $node.Expand()\par
        \}\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors du chargement des dossiers: $($_.Exception.Message)" -Level Error\par
        Show-ErrorMessage "Erreur" "Impossible de charger les dossiers: $($_.Exception.Message)"\par
    \} finally \{\par
        $TreeView.EndUpdate()\par
    \}\par
\}\par
\par
# Construction r\'e9cursive de l'arbre avec style uniforme\par
function Build-UniformFolderTree \{\par
    param(\par
        [System.Windows.Forms.TreeView]$TreeView,\par
        [System.Windows.Forms.TreeNode]$ParentNode,\par
        [string]$ParentDN,\par
        [hashtable]$FolderDict,\par
        [string]$CurrentUserPath\par
    )\par
    \par
    if ($FolderDict.ContainsKey($ParentDN)) \{\par
        foreach ($ou in ($FolderDict[$ParentDN] | Sort-Object Name)) \{\par
            # Noms d'affichage clairs et professionnels\par
            $displayName = Get-UniformFolderDisplayName $ou.Name\par
            \par
            # Cr\'e9ation du n\f3\u339?ud\par
            $node = if ($ParentNode) \{\par
                $ParentNode.Nodes.Add($displayName)\par
            \} else \{\par
                $TreeView.Nodes.Add($displayName)\par
            \}\par
            \par
            $node.Tag = $ou.DistinguishedName\par
            $node.Name = $ou.Name\par
            $node.ToolTipText = "Chemin complet : $($ou.DistinguishedName)"\par
            \par
            # Indication visuelle si c'est l'emplacement actuel\par
            if ($ou.DistinguishedName -eq $CurrentUserPath) \{\par
                $node.Text += " [EMPLACEMENT ACTUEL]"\par
                $node.ForeColor = $script:Theme.Primary\par
                $node.NodeFont = [System.Drawing.Font]::new("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)\par
            \}\par
            \par
            # Construction r\f0\'e9cursive des sous-dossiers\par
            Build-UniformFolderTree $TreeView $node $ou.DistinguishedName $FolderDict $CurrentUserPath\par
        \}\par
    \}\par
\}\par
