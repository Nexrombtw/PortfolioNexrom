function Search-ComputersInCityNeutral \{\par
    param(\par
        [string]$CityName,\par
        [string]$SearchTerm,\par
        [System.Windows.Forms.ListView]$ListView,\par
        [System.Windows.Forms.Label]$CountLabel,\par
        [bool]$ActiveOnly,\par
        [bool]$RecentLogonOnly,\par
        [string]$SearchType\par
    )\par
    \par
    try \{\par
        $ListView.Items.Clear()\par
        $searchBase = "OU=$CityName,$($script:Config.BaseOU)"\par
        \par
        # Construction du filtre selon le type de recherche\par
        $filter = switch ($SearchType) \{\par
            "all" \{\par
                if ([string]::IsNullOrWhiteSpace($SearchTerm)) \{\par
                    if ($ActiveOnly) \{ "Enabled -eq 'True'" \} else \{ "*" \}\par
                \} else \{\par
                    if ($ActiveOnly) \{\par
                        "((Name -like '*$SearchTerm*') -or (SerialNumber -like '*$SearchTerm*') -or (Description -like '*$SearchTerm*')) -and (Enabled -eq 'True')"\par
                    \} else \{\par
                        "(Name -like '*$SearchTerm*') -or (SerialNumber -like '*$SearchTerm*') -or (Description -like '*$SearchTerm*')"\par
                    \}\par
                \}\par
            \}\par
            "noserial" \{\par
                if ($ActiveOnly) \{\par
                    "Enabled -eq 'True'"\par
                \} else \{\par
                    "*"\par
                \}\par
            \}\par
        \}\par
        \par
        # R\'e9cup\'e9ration des ordinateurs\par
        $computers = Get-ADComputer -SearchBase $searchBase -Filter $filter -Properties Name, SerialNumber, Description, LastLogonDate, Enabled, DistinguishedName |\par
                    Sort-Object Name\par
        \par
        # Filtrage suppl\'e9mentaire pour les ordinateurs sans num\'e9ro de s\'e9rie\par
        if ($SearchType -eq "noserial") \{\par
            $computers = $computers | Where-Object \{ \par
                [string]::IsNullOrWhiteSpace($_.SerialNumber) -or \par
                $_.SerialNumber -eq "To be filled by O.E.M." -or \par
                $_.SerialNumber -eq "Default string" -or \par
                $_.SerialNumber -eq "System Serial Number" -or\par
                $_.SerialNumber -eq "Not Specified" -or\par
                $_.SerialNumber -eq "0" -or\par
                $_.SerialNumber.Length -lt 3\par
            \}\par
        \}\par
        \par
        # Filtrage par connexion r\'e9cente\par
        if ($RecentLogonOnly) \{\par
            $recentDate = (Get-Date).AddDays(-30)\par
            $computers = $computers | Where-Object \{ $_.LastLogonDate -and $_.LastLogonDate -gt $recentDate \}\par
        \}\par
        \par
        # Limitation des r\'e9sultats\par
        $computers = $computers | Select-Object -First 500\par
        \par
        # Remplissage de la ListView SANS colonne OS\par
        foreach ($computer in $computers) \{\par
            $item = New-Object System.Windows.Forms.ListViewItem($computer.Name)\par
            \par
            # Num\'e9ro de s\'e9rie\par
            $serialNumber = if ([string]::IsNullOrWhiteSpace($computer.SerialNumber) -or \par
                              $computer.SerialNumber -eq "To be filled by O.E.M." -or \par
                              $computer.SerialNumber -eq "Default string") \{\par
                "MANQUANT"\par
            \} else \{\par
                $computer.SerialNumber\par
            \}\par
            $null = $item.SubItems.Add($serialNumber)\par
            \par
            # Derni\'e8re connexion (index 2 au lieu de 3)\par
            $lastLogon = if ($computer.LastLogonDate) \{\par
                $daysDiff = (Get-Date) - $computer.LastLogonDate\par
                if ($daysDiff.Days -le 7) \{\par
                    "R\'c9CENT - $($computer.LastLogonDate.ToString('dd/MM/yyyy'))"\par
                \} elseif ($daysDiff.Days -le 30) \{\par
                    "MOYEN - $($computer.LastLogonDate.ToString('dd/MM/yyyy'))"\par
                \} else \{\par
                    "ANCIEN - $($computer.LastLogonDate.ToString('dd/MM/yyyy'))"\par
                \}\par
            \} else \{\par
                "JAMAIS"\par
            \}\par
            $null = $item.SubItems.Add($lastLogon)\par
            \par
            # \'c9tat (index 3 au lieu de 4)\par
            $status = if ($computer.Enabled) \{ "ACTIF" \} else \{ "INACTIF" \}\par
            $null = $item.SubItems.Add($status)\par
            \par
            # Description (index 4 au lieu de 5)\par
            $description = if ($computer.Description) \{ $computer.Description \} else \{ "Aucune" \}\par
            $null = $item.SubItems.Add($description)\par
            \par
            # Chemin AD (index 5 au lieu de 6)\par
            $adPath = $computer.DistinguishedName -replace "CN=$($computer.Name),", "" -replace ",DC=.*", ""\par
            $null = $item.SubItems.Add($adPath)\par
            \par
            # Couleur neutre uniquement pour les inactifs\par
            if (-not $computer.Enabled) \{\par
                $item.ForeColor = [System.Drawing.Color]::Gray\par
            \} else \{\par
                $item.ForeColor = $script:Theme.Text\par
            \}\par
            \par
            $null = $ListView.Items.Add($item)\par
        \}\par
        \par
        # Mise \'e0 jour du compteur\par
        $searchTypeText = switch ($SearchType) \{\par
            "all" \{ "tous crit\'e8res" \}\par
            "noserial" \{ "sans num\'e9ro de s\'e9rie" \}\par
        \}\par
        \par
        $CountLabel.Text = "$($computers.Count) ordinateur(s) trouv\'e9(s) ($searchTypeText) dans $CityName"\par
        $CountLabel.ForeColor = $script:Theme.Text\par
        \par
        Write-Log "Recherche d'ordinateurs dans $CityName : $($computers.Count) r\'e9sultats ($searchTypeText)" -Level Info\par
        \par
    \} catch \{\par
        Write-Log "Erreur lors de la recherche d'ordinateurs: $($_.Exception.Message)" -Level Error\par
        $CountLabel.Text = "Erreur lors de la recherche"\par
        $CountLabel.ForeColor = $script:Theme.Text\par
        Show-ErrorMessage "Erreur de recherche" "Impossible de rechercher les ordinateurs: $($_.Exception.Message)"\par
    \}\par
\}\par
